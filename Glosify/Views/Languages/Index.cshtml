@inject Glosify.Services.ILanguageContext LangContext
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Language selector";
    ViewData["ActiveNav"] = "languages";

    var languages = new[]
    {
        new { Name = "Estonian", Flag = "estonia" },
        new { Name = "German", Flag = "germany" },
        new { Name = "Polish", Flag = "poland" },
        new { Name = "Ukrainian", Flag = "ukraine" }
    };

    var current = LangContext.CurrentLanguage;
}

@section Styles {
<style>
    .language-page {
        display: flex;
        flex-direction: column;
        gap: 64px;
        padding-bottom: 64px;
    }

    .language-hero {
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 18px;
        align-items: center;
    }

    .language-brand {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #1DB954;
        margin: 0;
    }

    .language-tagline {
        font-size: clamp(32px, 5vw, 48px);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0;
        color: var(--on-surface);
        max-width: 880px;
    }

    .language-tagline .accent {
        background: linear-gradient(90deg, var(--primary), var(--primary-container));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .language-current {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 9999px;
        background: rgba(83, 224, 118, 0.12);
        color: var(--primary);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .language-form {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 24px;
        margin: 0;
        padding: 0;
        border: 0;
    }

    @@media (max-width: 1024px) {
        .language-form { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 600px) {
        .language-form { grid-template-columns: minmax(0, 1fr); }
    }

    .language-card {
        appearance: none;
        font: inherit;
        cursor: pointer;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 24px;
        padding: 36px 24px;
        border-radius: 24px;
        text-decoration: none;
        color: var(--on-surface);
        background: linear-gradient(135deg, rgba(44, 57, 81, 0.6) 0%, rgba(17, 32, 54, 0.6) 100%);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.10);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }

    .language-card:hover,
    .language-card:focus-visible {
        transform: scale(1.05);
        border-color: rgba(83, 224, 118, 0.32);
        box-shadow: 0 22px 50px rgba(0, 0, 0, 0.45);
        outline: none;
    }

    .language-card.is-current {
        border-color: var(--primary);
        box-shadow: 0 22px 50px rgba(83, 224, 118, 0.18);
    }

    .language-card.is-current::after {
        content: "Active";
        position: absolute;
        top: 14px;
        right: 14px;
        background: var(--primary);
        color: var(--on-primary);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 9999px;
    }

    .flag-frame {
        width: 96px;
        height: 64px;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease;
    }

    .language-card:hover .flag-frame,
    .language-card:focus-visible .flag-frame {
        transform: scale(1.1);
    }

    .flag-frame svg {
        display: block;
        width: 100%;
        height: 100%;
    }

    .language-name {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.01em;
        margin: 0;
        transition: color 0.3s ease;
    }

    .language-card:hover .language-name,
    .language-card:focus-visible .language-name,
    .language-card.is-current .language-name {
        color: var(--primary);
    }
</style>
}

<section class="language-page">
    <header class="language-hero">
        <h1 class="language-brand">Sonic Polyglot</h1>
        <h2 class="language-tagline">
            Where would you like to <span class="accent">resonate</span> today?
        </h2>
        @if (!string.IsNullOrEmpty(current))
        {
            <span class="language-current">
                <span class="material-symbols-outlined" style="font-size:18px;">check_circle</span>
                Currently learning @current
            </span>
        }
    </header>

    <form class="language-form" method="post" asp-controller="Languages" asp-action="Select">
        @Html.AntiForgeryToken()
        @foreach (var language in languages)
        {
            var isCurrent = string.Equals(current, language.Name, StringComparison.OrdinalIgnoreCase);
            <button class="language-card @(isCurrent ? "is-current" : "")" type="submit" name="language" value="@language.Name" aria-label="@language.Name" aria-pressed="@(isCurrent ? "true" : "false")">
                <span class="flag-frame">
                    @switch (language.Flag)
                    {
                        case "estonia":
                            <svg viewBox="0 0 3 2" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="3" height="2" fill="#0072CE" />
                                <rect y="0.6667" width="3" height="0.6667" fill="#000000" />
                                <rect y="1.3333" width="3" height="0.6667" fill="#FFFFFF" />
                            </svg>
                            break;
                        case "germany":
                            <svg viewBox="0 0 5 3" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="5" height="3" fill="#000000" />
                                <rect y="1" width="5" height="1" fill="#DD0000" />
                                <rect y="2" width="5" height="1" fill="#FFCE00" />
                            </svg>
                            break;
                        case "poland":
                            <svg viewBox="0 0 8 5" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="8" height="5" fill="#FFFFFF" />
                                <rect y="2.5" width="8" height="2.5" fill="#DC143C" />
                            </svg>
                            break;
                        case "ukraine":
                            <svg viewBox="0 0 3 2" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="3" height="2" fill="#0057B7" />
                                <rect y="1" width="3" height="1" fill="#FFD700" />
                            </svg>
                            break;
                    }
                </span>
                <span class="language-name">@language.Name</span>
            </button>
        }
    </form>
</section>
