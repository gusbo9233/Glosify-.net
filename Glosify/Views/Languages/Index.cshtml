@inject Glosify.Services.Language.ILanguageContext LangContext
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Language selector";
    ViewData["ActiveNav"] = "languages";

    var languages = new[]
    {
        new { Name = "Estonian", Flag = "estonia" },
        new { Name = "German", Flag = "germany" },
        new { Name = "Polish", Flag = "poland" },
        new { Name = "Ukrainian", Flag = "ukraine" }
    };

    var current = LangContext.CurrentLanguage;
}



<section class="language-page">
    <header class="language-hero">
        <h1 class="language-brand">Sonic Polyglot</h1>
        <h2 class="language-tagline">
            Where would you like to <span class="accent">resonate</span> today?
        </h2>
        @if (!string.IsNullOrEmpty(current))
        {
            <span class="language-current">
                    <span class="material-symbols-outlined icon-sm">check_circle</span>
                Currently learning @current
            </span>
        }
    </header>

    <form class="language-form" method="post" asp-controller="Languages" asp-action="Select">
        @Html.AntiForgeryToken()
        @foreach (var language in languages)
        {
            var isCurrent = string.Equals(current, language.Name, StringComparison.OrdinalIgnoreCase);
            <button class="language-card @(isCurrent ? "is-current" : "")" type="submit" name="language" value="@language.Name" aria-label="@language.Name" aria-pressed="@(isCurrent ? "true" : "false")">
                <span class="flag-frame">
                    @switch (language.Flag)
                    {
                        case "estonia":
                            <svg viewBox="0 0 3 2" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="3" height="2" fill="#0072CE" />
                                <rect y="0.6667" width="3" height="0.6667" fill="#000000" />
                                <rect y="1.3333" width="3" height="0.6667" fill="#FFFFFF" />
                            </svg>
                            break;
                        case "germany":
                            <svg viewBox="0 0 5 3" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="5" height="3" fill="#000000" />
                                <rect y="1" width="5" height="1" fill="#DD0000" />
                                <rect y="2" width="5" height="1" fill="#FFCE00" />
                            </svg>
                            break;
                        case "poland":
                            <svg viewBox="0 0 8 5" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="8" height="5" fill="#FFFFFF" />
                                <rect y="2.5" width="8" height="2.5" fill="#DC143C" />
                            </svg>
                            break;
                        case "ukraine":
                            <svg viewBox="0 0 3 2" preserveAspectRatio="none" role="img" aria-hidden="true">
                                <rect width="3" height="2" fill="#0057B7" />
                                <rect y="1" width="3" height="1" fill="#FFD700" />
                            </svg>
                            break;
                    }
                </span>
                <span class="language-name">@language.Name</span>
            </button>
        }
    </form>
</section>
