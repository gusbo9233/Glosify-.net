@model QuizSettingsViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Quiz Configuration";
    ViewData["ActiveNav"] = "quizzes";

    var quizName = Model.SelectedQuiz?.Name ?? "Flashcard Quiz";
    var availableWords = Model.AvailableWordCount;
    var availableSentences = Model.AvailableSentenceCount;
    var selectedWordCount = Model.SelectedWordCount;
    var tenCount = Math.Min(10, Math.Max(availableWords, 1));
    var twentyCount = Math.Min(20, Math.Max(availableWords, 1));
    var allCount = Math.Max(availableWords, 1);
    var sentenceTenCount = Math.Min(10, Math.Max(availableSentences, 1));
    var sentenceTwentyCount = Math.Min(20, Math.Max(availableSentences, 1));
    var sentenceAllCount = Math.Max(availableSentences, 1);
    var sourceLanguage = Model.SelectedQuiz?.SourceLanguage ?? "Source";
    var targetLanguage = Model.SelectedQuiz?.TargetLanguage ?? "Target";
}



<form class="settings-shell" method="post" asp-controller="Quiz" asp-action="Start">
    @Html.AntiForgeryToken()
    <input type="hidden" name="QuizId" value="@Model.SelectedQuiz?.Id" />

    <header class="settings-header">
        <span class="config-badge">Configuration</span>
        <h1 class="page-title">@quizName</h1>
        <p class="page-subtitle">Pick a quick practice run and review this quiz.</p>
    </header>

    <div class="settings-grid">
        <section class="settings-panel">
            <div>
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Session Length</h2>
                        <p class="section-note"><span data-available-count>@availableWords</span> <span data-available-label>words</span> available</p>
                    </div>
                    <span class="material-symbols-outlined">timer</span>
                </div>
                <div class="length-grid">
                    <label class="choice">
                        <input type="radio" name="WordCount" value="@tenCount" data-word-value="@tenCount" data-sentence-value="@sentenceTenCount" @(selectedWordCount <= 10 ? "checked" : "") />
                        <span class="choice-card"><span class="num" data-length-num>@tenCount</span><span class="label">Quick</span></span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="WordCount" value="@twentyCount" data-word-value="@twentyCount" data-sentence-value="@sentenceTwentyCount" @(selectedWordCount > 10 && selectedWordCount <= 20 ? "checked" : "") />
                        <span class="choice-card"><span class="num" data-length-num>@twentyCount</span><span class="label">Standard</span></span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="WordCount" value="@allCount" data-word-value="@allCount" data-sentence-value="@sentenceAllCount" @(selectedWordCount > 20 ? "checked" : "") />
                        <span class="choice-card"><span class="num" data-length-num>@allCount</span><span class="label">All</span></span>
                    </label>
                </div>
            </div>

            <div>
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Word Range</h2>
                        <p class="section-note">Drag either handle to focus on a slice of your list, e.g. just the newest words.</p>
                    </div>
                    <span class="material-symbols-outlined">tune</span>
                </div>
                <div class="range-presets">
                    <button type="button" class="range-preset" data-range-preset="0,100">All</button>
                    <button type="button" class="range-preset" data-range-preset="80,100">Newest 20%</button>
                    <button type="button" class="range-preset" data-range-preset="50,100">Newest 50%</button>
                    <button type="button" class="range-preset" data-range-preset="0,20">Oldest 20%</button>
                </div>
                <div class="range-slider" data-range-slider>
                    <div class="range-slider-track">
                        <div class="range-slider-fill" data-range-fill></div>
                    </div>
                    <input type="range" name="WordRangeStart" min="0" max="100" step="5" value="0" class="range-thumb range-thumb-min" data-range-min />
                    <input type="range" name="WordRangeEnd" min="0" max="100" step="5" value="100" class="range-thumb range-thumb-max" data-range-max />
                </div>
                <p class="range-slider-label" data-range-label>Practicing all words, oldest to newest.</p>

                <input type="hidden" name="SelectedWordIds" data-selected-word-ids value="" />
                <div class="word-picker-row" data-word-picker-row>
                    <button type="button" class="range-preset" data-open-word-picker>
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:-3px;">checklist</span>
                        Choose words individually&hellip;
                    </button>
                    <span class="word-picker-summary" data-word-picker-summary hidden></span>
                    <button type="button" class="word-picker-clear" data-clear-word-picker hidden>Clear selection</button>
                </div>

                <dialog class="word-picker-dialog" data-word-picker-dialog>
                    <div class="word-picker-header">
                        <h3>Choose words to practice</h3>
                        <button type="button" class="btn-icon" data-close-word-picker aria-label="Close">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <div class="word-picker-toolbar">
                        <button type="button" class="range-preset" data-select-all>Select all</button>
                        <button type="button" class="range-preset" data-deselect-all>Deselect all</button>
                        <input type="search" class="word-picker-search" placeholder="Filter words&hellip;" data-word-picker-search />
                        <span class="word-picker-count" data-word-picker-count></span>
                    </div>
                    <div class="word-picker-list">
                        @foreach (var word in Model.Words)
                        {
                            <label class="word-picker-item" data-word-picker-item data-lemma="@word.Lemma.ToLowerInvariant()" data-translation="@word.Translation.ToLowerInvariant()">
                                <input type="checkbox" class="word-picker-checkbox" data-word-picker-checkbox value="@word.Id" checked />
                                <span class="word-picker-lemma">@word.Lemma</span>
                                <span class="word-picker-translation">@word.Translation</span>
                            </label>
                        }
                    </div>
                    <div class="word-picker-footer">
                        <button type="button" class="btn-start" data-apply-word-picker>Apply selection</button>
                    </div>
                </dialog>
            </div>

            <div>
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Practice Content</h2>
                        <p class="section-note">Choose words or full sentences.</p>
                    </div>
                    <span class="material-symbols-outlined">subject</span>
                </div>
                <div class="mode-grid">
                    <label class="choice">
                        <input type="radio" name="PracticeItemType" value="words" checked data-item-label="Words" data-count="@availableWords" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">short_text</span>
                            <span class="mode-name">Words</span>
                        </span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="PracticeItemType" value="sentences" data-item-label="Sentences" data-count="@availableSentences" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">notes</span>
                            <span class="mode-name">Sentences</span>
                        </span>
                    </label>
                </div>
            </div>

            <div>
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Quiz Mode</h2>
                        <p class="section-note">Choose flashcards for recall or typing for active spelling practice.</p>
                    </div>
                    <span class="material-symbols-outlined">psychology</span>
                </div>
                <div class="mode-grid">
                    <label class="choice">
                        <input type="radio" name="Mode" value="flashcards" checked />
                        <span class="choice-card">
                            <span class="material-symbols-outlined material-symbols-filled">style</span>
                            <span class="mode-name">Flashcards</span>
                        </span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="Mode" value="typing" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">keyboard</span>
                            <span class="mode-name">Typing</span>
                        </span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="Mode" value="multiple-choice" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">checklist</span>
                            <span class="mode-name">Choices</span>
                        </span>
                    </label>
                </div>
            </div>

            <div>
                <div class="section-header">
                    <div>
                        <h2 class="section-title">Practice Direction</h2>
                        <p class="section-note">Choose which language appears first.</p>
                    </div>
                    <span class="material-symbols-outlined">swap_horiz</span>
                </div>
                <div class="mode-grid">
                    <label class="choice">
                        <input type="radio" name="PracticeDirection" value="source-to-target" checked data-direction-label="@sourceLanguage -> @targetLanguage" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">east</span>
                            <span class="mode-name">@sourceLanguage &rarr; @targetLanguage</span>
                        </span>
                    </label>
                    <label class="choice">
                        <input type="radio" name="PracticeDirection" value="target-to-source" data-direction-label="@targetLanguage -> @sourceLanguage" />
                        <span class="choice-card">
                            <span class="material-symbols-outlined">west</span>
                            <span class="mode-name">@targetLanguage &rarr; @sourceLanguage</span>
                        </span>
                    </label>
                </div>
            </div>
        </section>

        <aside class="start-panel">
            @if (availableWords == 0)
            {
                <div class="empty-callout" data-empty-callout>Add at least one word before starting a practice session.</div>
            }
            else
            {
                <div class="empty-callout" data-empty-callout hidden>Add at least one word before starting a practice session.</div>
            }
            <div class="stat-row"><span>Quiz</span><span>@quizName</span></div>
            <div class="stat-row"><span>Content</span><span data-selected-content>Words</span></div>
            <div class="stat-row"><span>Available</span><span data-selected-available>@availableWords</span></div>
            <div class="stat-row"><span>Mode</span><span data-selected-mode>Flashcards</span></div>
            <div class="stat-row"><span>Range</span><span data-selected-range>All</span></div>
            <div class="stat-row"><span>Direction</span><span data-selected-direction>@sourceLanguage -> @targetLanguage</span></div>
            <button class="btn-start" type="submit" data-start-button @(availableWords == 0 ? "disabled" : "")>
                <span class="material-symbols-outlined">play_circle</span>
                Start Quiz
            </button>
        </aside>
    </div>
</form>

@section Scripts {
<script src="~/js/quiz-settings.js" asp-append-version="true"></script>
}
