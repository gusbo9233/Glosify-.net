@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Glosify</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #041329;
            --surface-lowest: #010e24;
            --surface-low: #0d1c32;
            --surface: #112036;
            --surface-high: #1c2a41;
            --surface-highest: #27354c;
            --surface-bright: #2c3951;
            --on-surface: #d6e3ff;
            --on-surface-var: #bccbb9;
            --primary: #53e076;
            --primary-container: #1db954;
            --on-primary: #003914;
            --on-primary-container: #004118;
            --error: #ffb4ab;
            --outline-var: #3d4a3d;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--on-surface);
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--surface-lowest); }
        ::-webkit-scrollbar-thumb { background: var(--surface-highest); border-radius: 10px; }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 256px;
            height: 100vh;
            background: var(--surface-lowest);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .sidebar-brand { padding: 0 32px 48px; }
        .sidebar-brand h1 {
            color: var(--primary-container);
            font-size: 22px;
            font-weight: 900;
            font-style: italic;
            letter-spacing: -0.05em;
        }
        .sidebar-brand p {
            color: var(--on-surface-var);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-weight: 700;
            margin-top: 4px;
        }

        .sidebar nav {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 0 16px;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--surface-highest);
            text-decoration: none;
            border-radius: 9999px;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s, background 0.2s;
        }
        .nav-item:hover { color: var(--primary); background: var(--surface); }
        .nav-item.active { background: var(--surface); color: var(--primary-container); font-weight: 700; }

        .sidebar-bottom { padding: 0 24px; margin-top: 16px; }

        .btn-sidebar-cta {
            width: 100%;
            background: var(--primary-container);
            color: var(--on-primary);
            padding: 12px;
            border-radius: 9999px;
            font-weight: 700;
            font-size: 14px;
            border: none;
            cursor: pointer;
            transition: transform 0.2s;
            box-shadow: 0 4px 15px rgba(29,185,84,0.15);
        }
        .btn-sidebar-cta:hover { transform: scale(1.05); }
        .btn-sidebar-cta:active { transform: scale(0.95); }

        .sidebar-footer-links {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid rgba(61,74,61,0.4);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .sidebar-footer-links a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 16px;
            color: var(--surface-highest);
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .sidebar-footer-links a:hover { color: var(--primary); }
        .sidebar-footer-links .material-symbols-outlined { font-size: 18px; }

        /* ── Page wrapper (sits next to sidebar) ── */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
            min-width: 0;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h1>Glosify</h1>
            <p>Language Learning</p>
        </div>
        <nav>
            <a class="nav-item" href="#"><span class="material-symbols-outlined">subscriptions</span>Library</a>
            <a class="nav-item @(ViewData["ActiveNav"]?.ToString() == "quizzes" ? "active" : "")" asp-controller="Quiz" asp-action="Index">
                <span class="material-symbols-outlined">quiz</span>Quiz Master
            </a>
            <a class="nav-item" href="#"><span class="material-symbols-outlined">auto_awesome</span>Sonic Lab</a>
            <a class="nav-item" href="#"><span class="material-symbols-outlined">equalizer</span>Analytics</a>
        </nav>
        <div class="sidebar-bottom">
            <button class="btn-sidebar-cta" onclick="location.href='@Url.Action("Index", "Quiz")'">Quiz Master</button>
            <div class="sidebar-footer-links">
                <a href="#"><span class="material-symbols-outlined">settings</span>Settings</a>
                <a href="#"><span class="material-symbols-outlined">help_outline</span>Support</a>
            </div>
        </div>
    </aside>

    <div class="page-wrapper">
        @RenderBody()
    </div>
</body>
</html>
