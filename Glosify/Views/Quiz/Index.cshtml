@model QuizIndexViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Select Quiz";
    ViewData["ActiveNav"] = "quizzes";

    var currentLanguage = Model.CurrentLanguage;
    var currentCollection = Model.CurrentCollection;
    var currentCollectionId = currentCollection?.Id;
    var childCollections = Model.Collections.Where(collection => collection.ParentCollectionId == currentCollectionId).ToList();
    var visibleQuizzes = Model.Quizzes.Where(quiz => quiz.CollectionId == currentCollectionId).ToList();
    var pageTitle = currentCollection?.Name ?? "Select a quiz";
    var pageSubtitle = currentCollection == null
        ? $"Showing your {currentLanguage} quizzes."
        : $"{currentLanguage} collection.";
}

<section class="select-quiz-page" data-quiz-library data-move-quiz-url="@Url.Action("MoveQuizToCollection", "Quiz")">
    <header class="select-header">
        <div>
            <p class="select-kicker">Quiz Library - @currentLanguage</p>
            <h1 class="select-title">@pageTitle</h1>
            <p class="select-subtitle">
                @pageSubtitle
                @if (currentCollection == null)
                {
                    <a class="language-change-link" asp-controller="Languages" asp-action="Index">Change language</a>
                }
            </p>
            @if (currentCollection != null)
            {
                <form class="share-form collection-share-form" method="post" asp-controller="Quiz" asp-action="SetCollectionVisibility" asp-route-id="@currentCollection.Id">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="isPublic" value="@(currentCollection.IsPublic ? "false" : "true")" />
                    <button class="btn-inline-share" type="submit">
                        <span class="material-symbols-outlined">@(currentCollection.IsPublic ? "lock" : "public")</span>
                        @(currentCollection.IsPublic ? "Make collection private" : "Make collection public")
                    </button>
                    <span class="status-pill">@(currentCollection.IsPublic ? "Public subtree" : "Private")</span>
                </form>
            }
        </div>
        <div class="select-actions">
            @if (currentCollection != null)
            {
                if (Model.ParentCollection != null)
                {
                    <a class="btn-new-quiz btn-back-library" asp-controller="Quiz" asp-action="Collection" asp-route-id="@Model.ParentCollection.Id">
                        <span class="material-symbols-outlined">arrow_back</span>
                        Back
                    </a>
                }
                else
                {
                    <a class="btn-new-quiz btn-back-library" asp-controller="Quiz" asp-action="Index">
                        <span class="material-symbols-outlined">arrow_back</span>
                        Back
                    </a>
                }
            }
            <button class="btn-new-quiz btn-secondary-action" type="button" data-modal-open="createCollectionModal">
                <span class="material-symbols-outlined">create_new_folder</span>
                New Collection
            </button>
            <button class="btn-new-quiz" type="button" data-modal-open="createModal">
                <span class="material-symbols-outlined">add</span>
                New Quiz
            </button>
        </div>
    </header>

    @if (TempData["QuizMessage"] is string quizMessage)
    {
        <div class="page-message">@quizMessage</div>
    }

    @if (childCollections.Any())
    {
        <section class="library-section" aria-labelledby="collectionsHeading">
            <div class="library-section-header">
                <h2 id="collectionsHeading">Collections</h2>
                <span>@childCollections.Count</span>
            </div>
            <div class="quiz-grid">
                @foreach (var collection in childCollections)
                {
                    var childCollectionCount = Model.Collections.Count(child => child.ParentCollectionId == collection.Id);
                    var quizCount = Model.Quizzes.Count(quiz => quiz.CollectionId == collection.Id);

                    <article class="quiz-card collection-card"
                             data-collection-drop-target
                             data-collection-id="@collection.Id"
                             aria-label="Drop quizzes into @collection.Name">
                        <a class="quiz-card-link" asp-controller="Quiz" asp-action="Collection" asp-route-id="@collection.Id">
                            <div class="quiz-card-top">
                                <div class="quiz-icon collection-icon"><span class="material-symbols-outlined">folder</span></div>
                                <span class="material-symbols-outlined quiz-arrow">arrow_forward</span>
                            </div>
                            <h2 class="quiz-name">@collection.Name</h2>
                            <p class="quiz-languages">@collection.Language</p>
                        </a>
                        <div class="quiz-meta">
                            <span>@collection.CreatedAt.ToString("MMM d, yyyy")</span>
                            <span class="status-pill">@quizCount quizzes / @childCollectionCount nested</span>
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    @if (visibleQuizzes.Any())
    {
        <section class="library-section" aria-labelledby="quizzesHeading">
            <div class="library-section-header">
                <h2 id="quizzesHeading">Quizzes</h2>
                <span>@visibleQuizzes.Count</span>
            </div>
            <div class="quiz-grid">
                @foreach (var quiz in visibleQuizzes)
                {
                    <article class="quiz-card"
                             draggable="true"
                             data-quiz-card
                             data-quiz-id="@quiz.Id">
                        <a class="quiz-card-link" draggable="false" asp-controller="Quiz" asp-action="Details" asp-route-id="@quiz.Id">
                            <div class="quiz-card-top">
                                <div class="quiz-icon"><span class="material-symbols-outlined">quiz</span></div>
                                <span class="material-symbols-outlined quiz-arrow">arrow_forward</span>
                            </div>
                            <h2 class="quiz-name">@quiz.Name</h2>
                            <p class="quiz-languages">@quiz.SourceLanguage &rarr; @quiz.TargetLanguage</p>
                        </a>
                        <div class="quiz-meta">
                            <span>@quiz.CreatedAt.ToString("MMM d, yyyy")</span>
                            <span class="status-pill">@quiz.ProcessingStatus</span>
                        </div>
                        <form class="delete-form" method="post" asp-controller="Quiz" asp-action="DeleteQuiz" asp-route-id="@quiz.Id" data-confirm="Delete this quiz and all of its words?">
                            @Html.AntiForgeryToken()
                            <button class="btn-delete" type="submit" aria-label="Delete @quiz.Name">
                                <span class="material-symbols-outlined">delete</span>
                                Delete
                            </button>
                        </form>
                    </article>
                }
            </div>
        </section>
    }
    else if (!childCollections.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><span class="material-symbols-outlined">library_add</span></div>
            <h2 class="empty-title">No quizzes or collections yet</h2>
            <p class="empty-copy">Create a collection to organize your vocabulary, or create your first quiz.</p>
            <div class="empty-actions">
                <button class="btn-new-quiz btn-secondary-action" type="button" data-modal-open="createCollectionModal">
                    <span class="material-symbols-outlined">create_new_folder</span>
                    Create Collection
                </button>
                <button class="btn-new-quiz" type="button" data-modal-open="createModal">
                    <span class="material-symbols-outlined">add</span>
                    Create Quiz
                </button>
            </div>
        </div>
    }
</section>

<div class="modal-backdrop" id="createCollectionModal">
    <div class="modal">
        <h2 class="modal-title">Create New Collection</h2>
        <form method="post" asp-controller="Quiz" asp-action="CreateCollection">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Collection Name</label>
                <input class="form-input" type="text" name="Name" placeholder="e.g. Travel phrases" required />
            </div>
            <input type="hidden" name="ParentCollectionId" value="@currentCollectionId" />
            <div class="modal-actions">
                <button type="button" class="btn-cancel" data-modal-close>Cancel</button>
                <button type="submit" class="btn-create">Create Collection</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/quiz-library.js" asp-append-version="true"></script>
}

<div class="modal-backdrop" id="createModal">
    <div class="modal">
        <h2 class="modal-title">Create New Quiz</h2>
        <form method="post" asp-controller="Quiz" asp-action="Create">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CollectionId" value="@currentCollectionId" />
            <div class="form-group">
                <label class="form-label">Quiz Name</label>
                <input class="form-input" type="text" name="Name" placeholder="e.g. French Basics" required />
            </div>
            <div class="form-group">
                <label class="form-label">Source Language</label>
                <select class="select-input" name="SourceLanguage" required>
                    <option value="">Select language...</option>
                    <option>English</option>
                    <option>Swedish</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Target Language</label>
                <input type="hidden" name="TargetLanguage" value="@currentLanguage" />
                <div class="form-input target-language-display">
                    <span>@currentLanguage</span>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" data-modal-close>Cancel</button>
                <button type="submit" class="btn-create">Create Quiz</button>
            </div>
        </form>
    </div>
</div>
