@model Glosify.Models.QuizWorkspaceViewModel
@{ Layout = "~/Views/Shared/_AppLayout.cshtml"; ViewData["Title"] = Model.SelectedQuiz.Name; ViewData["ActiveNav"] = "quizzes"; }

@section Styles {
<style>
    .workspace {
        display: flex;
        flex-direction: column;
        gap: 32px;
        padding-bottom: 48px;
    }

    .workspace-hero {
        position: relative;
        min-height: 220px;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: 8px;
        padding: 48px;
        background: var(--surface-low);
    }

    .workspace-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(4, 19, 41, 0.96), rgba(4, 19, 41, 0.68), rgba(4, 19, 41, 0.28)),
            url("https://lh3.googleusercontent.com/aida-public/AB6AXuD9ss3rayFXW6xbDfKwaWBT4tK6nB7OYhS-_oAQ5EUQg0LV37lAgcAP0BfOGQjIP0OUbut82CxKStIFZxhrIXMToHIrYGohkAar3phWh2_YkdFuYTZD2EyHJAqdz9X0ygdDjHTzQMns53BMNCvUs17_ySAgafcimd1KyITVfwOJsxh_AIQVAvn8H3vAFgjRS-HirR_bhEEFTX4B0vbAxC-Uf2m3uv0JbgFoTnvNJKNHLZOWu1XmnMRfBZAUCY8S1gr4YTaV25E58IrV") center/cover;
    }

    .workspace-hero-content {
        position: relative;
        z-index: 1;
        max-width: 620px;
    }

    .hero-label {
        color: var(--primary);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .hero-title {
        font-size: 40px;
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1.05;
        margin: 0 0 24px;
    }

    .btn-hero,
    .btn-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border: none;
        border-radius: 9999px;
        background: var(--primary-container);
        color: var(--on-primary);
        font-weight: 850;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-hero {
        padding: 15px 30px;
        box-shadow: 0 14px 34px rgba(29, 185, 84, 0.24);
    }

    .btn-submit {
        width: 100%;
        padding: 15px 20px;
    }

    .btn-hero:hover,
    .btn-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 42px rgba(29, 185, 84, 0.28);
    }

    .tool-grid {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(0, 2fr);
        gap: 24px;
    }

    .panel {
        background: var(--surface);
        border: 1px solid rgba(61, 74, 61, 0.28);
        border-radius: 8px;
        padding: 28px;
    }

    .panel-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 22px;
    }

    .panel-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border-radius: 9999px;
        background: rgba(83, 224, 118, 0.1);
        color: var(--primary);
    }

    .panel-title {
        font-size: 18px;
        font-weight: 800;
        margin: 0;
    }

    .form-group { margin-bottom: 16px; }

    .panel-message {
        border-radius: 8px;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.4;
        margin-bottom: 16px;
        padding: 12px 14px;
    }

    .panel-message.success {
        background: rgba(83, 224, 118, 0.12);
        color: var(--primary);
    }

    .panel-message.error {
        background: rgba(255, 96, 96, 0.14);
        color: #ffb4b4;
    }

    .form-label {
        display: block;
        color: var(--on-surface-var);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        background: var(--surface-highest);
        color: var(--on-surface);
        border: none;
        border-radius: 9999px;
        padding: 13px 18px;
        font: inherit;
        outline: none;
    }

    .form-textarea {
        min-height: 150px;
        resize: vertical;
        border-radius: 8px;
        background: var(--surface-lowest);
        padding: 18px;
    }

    .form-input:focus,
    .form-textarea:focus {
        box-shadow: 0 0 0 2px var(--primary);
    }

    .collection-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        margin-bottom: 18px;
    }

    .collection-title {
        font-size: 24px;
        font-weight: 900;
        letter-spacing: -0.03em;
        margin: 0;
    }

    .collection-subtitle {
        color: var(--on-surface-var);
        font-size: 14px;
        margin: 5px 0 0;
    }

    .tab-group {
        display: flex;
        flex-shrink: 0;
        background: var(--surface);
        border-radius: 9999px;
        padding: 4px;
    }

    .tab {
        border: none;
        border-radius: 9999px;
        background: transparent;
        color: var(--on-surface-var);
        padding: 8px 22px;
        font-weight: 800;
    }

    .tab.active {
        background: var(--primary);
        color: var(--on-primary);
    }

    .word-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .tab-panel[hidden] {
        display: none;
    }

    .sentence-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 16px;
    }

    .sentence-card {
        display: grid;
        gap: 14px;
        min-height: 140px;
        background: var(--surface-low);
        border: 1px solid rgba(61, 74, 61, 0.22);
        border-radius: 8px;
        padding: 22px;
    }

    .sentence-card-top {
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .sentence-text {
        color: var(--on-surface);
        font-size: 17px;
        font-weight: 800;
        line-height: 1.45;
        overflow-wrap: anywhere;
    }

    .sentence-translation {
        color: var(--on-surface-var);
        font-size: 14px;
        font-weight: 650;
        line-height: 1.5;
        overflow-wrap: anywhere;
    }

    .sentence-meta {
        color: rgba(188, 203, 185, 0.68);
        font-size: 12px;
        font-weight: 750;
    }

    .word-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        min-height: 100px;
        background: var(--surface-low);
        border: 1px solid rgba(61, 74, 61, 0.22);
        border-radius: 8px;
        padding: 22px;
        transition: border-color 0.2s, transform 0.2s, background 0.2s;
    }

    .word-card:hover {
        transform: translateY(-2px);
        border-color: rgba(83, 224, 118, 0.52);
        background: var(--surface);
    }

    .word-card-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        min-width: 0;
        flex: 1;
        color: inherit;
        text-decoration: none;
    }

    .word-card-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .word-icon {
        width: 46px;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border-radius: 8px;
        background: var(--surface-highest);
        color: var(--primary);
    }

    .word {
        font-size: 18px;
        font-weight: 850;
        overflow-wrap: anywhere;
    }

    .translation {
        color: var(--on-surface-var);
        font-size: 14px;
        font-weight: 650;
        margin-top: 3px;
        overflow-wrap: anywhere;
    }

    .word-date {
        color: rgba(188, 203, 185, 0.65);
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .word-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .delete-word-form {
        margin: 0;
    }

    .btn-icon-delete {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 96, 96, 0.28);
        border-radius: 9999px;
        background: rgba(255, 96, 96, 0.08);
        color: #ffb4b4;
        cursor: pointer;
    }

    .btn-icon-delete .material-symbols-outlined {
        font-size: 20px;
    }

    .btn-icon-delete:hover {
        background: rgba(255, 96, 96, 0.16);
        border-color: rgba(255, 96, 96, 0.48);
    }

    .empty-state {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 180px;
        color: var(--on-surface-var);
        background: var(--surface-low);
        border: 1px dashed rgba(83, 224, 118, 0.35);
        border-radius: 8px;
        text-align: center;
        padding: 32px;
    }

    @@media (max-width: 900px) {
        .tool-grid { grid-template-columns: 1fr; }
        .collection-header { align-items: flex-start; flex-direction: column; }
    }
</style>
}

<section class="workspace">
    <section class="workspace-hero">
        <div class="workspace-hero-content">
            <p class="hero-label">@Model.SelectedQuiz.SourceLanguage &rarr; @Model.SelectedQuiz.TargetLanguage</p>
            <h1 class="hero-title">@Model.SelectedQuiz.Name</h1>
            <a asp-controller="Quiz" asp-action="Settings" asp-route-id="@Model.SelectedQuiz.Id" class="btn-hero">
                Start Quiz <span class="material-symbols-outlined">play_circle</span>
            </a>
        </div>
    </section>

    <div class="tool-grid">
        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">add_circle</span></div>
                <h2 class="panel-title">Quick Add</h2>
            </div>
            <form method="post" asp-controller="Quiz" asp-action="AddWord">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quizId" value="@Model.SelectedQuiz.Id" />
                <div class="form-group">
                    <label class="form-label">Word</label>
                    <input class="form-input" type="text" name="word" placeholder="e.g. Bibliotheque" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Translation</label>
                    <input class="form-input" type="text" name="translation" placeholder="e.g. Library" required />
                </div>
                <button class="btn-submit" type="submit">Add Word</button>
            </form>
        </section>

        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">auto_awesome</span></div>
                <h2 class="panel-title">AI Assistant</h2>
            </div>
            @if (TempData["AiMessage"] is string aiMessage)
            {
                <div class="panel-message success">@aiMessage</div>
            }
            @if (TempData["AiError"] is string aiError)
            {
                <div class="panel-message error">@aiError</div>
            }
            @if (TempData["QuizMessage"] is string quizMessage)
            {
                <div class="panel-message success">@quizMessage</div>
            }
            <form method="post" asp-controller="Quiz" asp-action="GenerateWords">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quizId" value="@Model.SelectedQuiz.Id" />
                <div class="form-group">
                    <label class="form-label">Source Text</label>
                    <textarea class="form-textarea" name="input" placeholder="Paste an article, lyrics, or transcript here to extract key vocabulary automatically..." required></textarea>
                </div>
                <button class="btn-submit" type="submit">
                    Generate Words <span class="material-symbols-outlined">auto_awesome</span>
                </button>
            </form>
        </section>
    </div>

    <section>
        <div class="collection-header">
            <div>
                <h2 class="collection-title" id="collectionTitle">Words</h2>
                <p class="collection-subtitle" id="collectionSubtitle">@Model.Words.Count words in @Model.SelectedQuiz.Name</p>
            </div>
            <div class="tab-group" role="tablist" aria-label="Quiz content">
                <button class="tab active" type="button" role="tab" aria-selected="true" aria-controls="wordsPanel" data-tab="words">Words</button>
                <button class="tab" type="button" role="tab" aria-selected="false" aria-controls="sentencesPanel" data-tab="sentences">Sentences</button>
            </div>
        </div>

        <div class="tab-panel" id="wordsPanel" data-title="Words" data-subtitle="@Model.Words.Count words in @Model.SelectedQuiz.Name">
            <div class="word-grid">
                @foreach (var word in Model.Words)
                {
                    <article class="word-card">
                        <a class="word-card-link" asp-controller="WordDetails" asp-action="Details" asp-route-id="@word.WordDetailId" aria-label="Open details for @word.Lemma">
                            <div class="word-card-left">
                                <div class="word-icon"><span class="material-symbols-outlined">translate</span></div>
                                <div>
                                    <div class="word">@word.Lemma</div>
                                    <div class="translation">@word.Translation</div>
                                </div>
                            </div>
                        </a>
                        <div class="word-actions">
                            <a class="word-date" asp-controller="WordDetails" asp-action="Details" asp-route-id="@word.WordDetailId">Open</a>
                            <form class="delete-word-form" method="post" asp-controller="Quiz" asp-action="DeleteWord" asp-route-id="@word.Id" onsubmit="return confirm('Delete this word?');">
                                @Html.AntiForgeryToken()
                                <button class="btn-icon-delete" type="submit" aria-label="Delete @word.Lemma">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </form>
                        </div>
                    </article>
                }
                @if (!Model.Words.Any())
                {
                    <div class="empty-state">No words yet. Add the first word with Quick Add.</div>
                }
            </div>
        </div>

        <div class="tab-panel" id="sentencesPanel" data-title="Sentences" data-subtitle="@Model.Sentences.Count sentences in @Model.SelectedQuiz.Name" hidden>
            <div class="sentence-grid">
                @foreach (var sentence in Model.Sentences)
                {
                    <article class="sentence-card">
                        <div class="sentence-card-top">
                            <div class="word-icon"><span class="material-symbols-outlined">format_quote</span></div>
                            <div>
                                <div class="sentence-text">@sentence.Text</div>
                                @if (!string.IsNullOrWhiteSpace(sentence.Translation))
                                {
                                    <div class="sentence-translation">@sentence.Translation</div>
                                }
                            </div>
                        </div>
                        <div class="sentence-meta">@sentence.WordCount linked @(sentence.WordCount == 1 ? "word" : "words")</div>
                    </article>
                }
                @if (!Model.Sentences.Any())
                {
                    <div class="empty-state">No sentences yet. Generate words from sentences or phrases to fill this tab.</div>
                }
            </div>
        </div>
    </section>
</section>

@section Scripts {
<script>
    (() => {
        const tabs = document.querySelectorAll('[data-tab]');
        const panels = {
            words: document.getElementById('wordsPanel'),
            sentences: document.getElementById('sentencesPanel')
        };
        const title = document.getElementById('collectionTitle');
        const subtitle = document.getElementById('collectionSubtitle');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const activeTab = tab.dataset.tab;
                tabs.forEach(item => {
                    const isActive = item === tab;
                    item.classList.toggle('active', isActive);
                    item.setAttribute('aria-selected', isActive.toString());
                });

                Object.entries(panels).forEach(([name, panel]) => {
                    if (panel) {
                        panel.hidden = name !== activeTab;
                    }
                });

                const activePanel = panels[activeTab];
                if (activePanel && title && subtitle) {
                    title.textContent = activePanel.dataset.title || "";
                    subtitle.textContent = activePanel.dataset.subtitle || "";
                }
            });
        });
    })();
</script>
}
