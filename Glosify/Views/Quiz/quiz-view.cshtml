@model QuizWorkspaceViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = Model.SelectedQuiz.Name;
    ViewData["ActiveNav"] = "quizzes";

    var pendingGenerationCount = Model.Words.Count(w => !Model.EnrichedWordDetailIds.Contains(w.WordDetailId));
}



<section class="workspace">
    <section class="workspace-hero">
        <div class="workspace-hero-content">
            <p class="hero-label">@Model.SelectedQuiz.SourceLanguage &rarr; @Model.SelectedQuiz.TargetLanguage</p>
            <h1 class="hero-title">@Model.SelectedQuiz.Name</h1>
            <div class="hero-actions">
                <a asp-controller="Quiz" asp-action="Settings" asp-route-id="@Model.SelectedQuiz.Id" class="btn-hero">
                    Start Quiz <span class="material-symbols-outlined">play_circle</span>
                </a>
                <button id="bulkGenerateButton"
                        type="button"
                        class="btn-hero btn-hero-secondary"
                        data-pending-count="@pendingGenerationCount"
                        @(pendingGenerationCount == 0 ? "hidden" : "")>
                    <span class="bulk-generate-label">Generate word details (@pendingGenerationCount)</span>
                    <span class="material-symbols-outlined">auto_awesome</span>
                </button>
            </div>
        </div>
    </section>
    @Html.AntiForgeryToken()

    <div class="tool-grid">
        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">add_circle</span></div>
                <h2 class="panel-title">Quick Add</h2>
            </div>
            <form method="post" asp-controller="Quiz" asp-action="AddWord">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quizId" value="@Model.SelectedQuiz.Id" />
                <div class="form-group">
                    <label class="form-label">Word</label>
                    <input class="form-input" type="text" name="word" placeholder="e.g. Bibliotheque" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Translation</label>
                    <input class="form-input" type="text" name="translation" placeholder="e.g. Library" required />
                </div>
                <button class="btn-submit" type="submit">Add Word</button>
            </form>
        </section>

        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">auto_awesome</span></div>
                <h2 class="panel-title">AI Assistant</h2>
            </div>
            @if (TempData["AiMessage"] is string aiMessage)
            {
                <div class="panel-message success">@aiMessage</div>
            }
            @if (TempData["AiError"] is string aiError)
            {
                <div class="panel-message error">@aiError</div>
            }
            @if (TempData["QuizMessage"] is string quizMessage)
            {
                <div class="panel-message success">@quizMessage</div>
            }
            <form method="post" asp-controller="Quiz" asp-action="GenerateWords">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quizId" value="@Model.SelectedQuiz.Id" />
                <div class="form-group">
                    <label class="form-label">AI Model</label>
                    <select class="form-input" name="aiProvider">
                        <option value="openai" selected>GPT-5.5</option>
                        <option value="gemini">Gemini 3.1 Pro</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Source Text</label>
                    <div class="scan-toolbar">
                        <button class="btn-scan-text"
                                type="button"
                                data-scan-text-button
                                data-extract-url="@Url.Action("ExtractTextFromImage", "Quiz")"
                                data-quiz-id="@Model.SelectedQuiz.Id">
                            <span class="material-symbols-outlined">photo_camera</span>
                            Scan text
                        </button>
                        <span class="scan-status" data-scan-status aria-live="polite"></span>
                    </div>
                    <input class="visually-hidden"
                           type="file"
                           accept="image/*"
                           capture="environment"
                           data-image-text-input />
                    <textarea class="form-textarea" id="aiSourceText" name="input" data-source-textarea placeholder="Paste an article, lyrics, or transcript here to extract key vocabulary automatically..." required></textarea>
                </div>
                <button class="btn-submit" type="submit">
                    Generate Words <span class="material-symbols-outlined">auto_awesome</span>
                </button>
            </form>
        </section>
    </div>

    <section>
        <div class="collection-header">
            <div>
                <h2 class="collection-title" id="collectionTitle">Words</h2>
                <p class="collection-subtitle" id="collectionSubtitle">@Model.Words.Count words in @Model.SelectedQuiz.Name</p>
            </div>
            <div class="tab-group" role="tablist" aria-label="Quiz content">
                <button class="tab active" type="button" role="tab" aria-selected="true" aria-controls="wordsPanel" data-tab="words">Words</button>
                <button class="tab" type="button" role="tab" aria-selected="false" aria-controls="sentencesPanel" data-tab="sentences">Sentences</button>
            </div>
        </div>

        <div class="tab-panel" id="wordsPanel" data-title="Words" data-subtitle="@Model.Words.Count words in @Model.SelectedQuiz.Name">
            <div class="word-grid">
                @foreach (var word in Model.Words)
                {
                    var needsGeneration = !Model.EnrichedWordDetailIds.Contains(word.WordDetailId);
                    <article class="word-card"
                             data-word-detail-id="@word.WordDetailId"
                             data-needs-generation="@(needsGeneration ? "true" : "false")">
                        <a class="word-card-link" asp-controller="WordDetails" asp-action="Details" asp-route-id="@word.WordDetailId" aria-label="Open details for @word.Lemma">
                            <div class="word-card-left">
                                <div class="word-icon"><span class="material-symbols-outlined">translate</span></div>
                                <div>
                                    <div class="word">@word.Lemma</div>
                                    <div class="translation">@word.Translation</div>
                                </div>
                            </div>
                        </a>
                        <div class="word-actions">
                            <a class="word-date" asp-controller="WordDetails" asp-action="Details" asp-route-id="@word.WordDetailId">Open</a>
                            <form class="delete-word-form" method="post" asp-controller="Quiz" asp-action="DeleteWord" asp-route-id="@word.Id" onsubmit="return confirm('Delete this word?');">
                                @Html.AntiForgeryToken()
                                <button class="btn-icon-delete" type="submit" aria-label="Delete @word.Lemma">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </form>
                        </div>
                    </article>
                }
                @if (!Model.Words.Any())
                {
                    <div class="empty-state">No words yet. Add the first word with Quick Add.</div>
                }
            </div>
        </div>

        <div class="tab-panel" id="sentencesPanel" data-title="Sentences" data-subtitle="@Model.Sentences.Count sentences in @Model.SelectedQuiz.Name" hidden>
            <div class="sentence-grid">
                @foreach (var sentence in Model.Sentences)
                {
                    <article class="sentence-card">
                        <div class="sentence-card-top">
                            <div class="word-icon"><span class="material-symbols-outlined">format_quote</span></div>
                            <div>
                                <div class="sentence-text">@sentence.Text</div>
                                @if (!string.IsNullOrWhiteSpace(sentence.Translation))
                                {
                                    <div class="sentence-translation">@sentence.Translation</div>
                                }
                            </div>
                        </div>
                        <div class="sentence-meta">@sentence.WordCount linked @(sentence.WordCount == 1 ? "word" : "words")</div>
                    </article>
                }
                @if (!Model.Sentences.Any())
                {
                    <div class="empty-state">No sentences yet. Generate words from sentences or phrases to fill this tab.</div>
                }
            </div>
        </div>
    </section>
</section>

@section Scripts {
<script>
    const resetWordLoadingState = () => {
        document.querySelectorAll('.word-card.loading').forEach(card => {
            card.classList.remove('loading');
            const icon = card.querySelector('.word-icon .material-symbols-outlined');
            if (icon) icon.textContent = icon.dataset.defaultIcon || 'translate';
        });
    };

    document.querySelectorAll('.word-card-link, .word-date').forEach(link => {
        link.addEventListener('click', event => {
            if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                return;
            }

            const card = link.closest('.word-card');
            if (!card) return;

            card.classList.add('loading');
            const icon = card.querySelector('.word-icon .material-symbols-outlined');
            if (icon) {
                icon.dataset.defaultIcon ||= icon.textContent.trim() || 'translate';
                icon.textContent = 'progress_activity';
            }

            window.setTimeout(() => {
                if (document.visibilityState === 'visible') {
                    card.classList.remove('loading');
                    if (icon) icon.textContent = icon.dataset.defaultIcon || 'translate';
                }
            }, 12000);
        });
    });

    window.addEventListener('pageshow', resetWordLoadingState);

    (() => {
        const scanButton = document.querySelector('[data-scan-text-button]');
        const imageInput = document.querySelector('[data-image-text-input]');
        const textarea = document.querySelector('[data-source-textarea]');
        const status = document.querySelector('[data-scan-status]');
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

        if (!scanButton || !imageInput || !textarea || !status) return;

        const setStatus = (message, isError = false) => {
            status.textContent = message;
            status.classList.toggle('is-error', isError);
        };

        scanButton.addEventListener('click', () => {
            imageInput.click();
        });

        imageInput.addEventListener('change', async () => {
            const file = imageInput.files?.[0];
            if (!file) return;

            const body = new FormData();
            body.append('quizId', scanButton.dataset.quizId || '');
            body.append('image', file);

            scanButton.disabled = true;
            setStatus('Reading image...');

            try {
                const response = await fetch(scanButton.dataset.extractUrl || '', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'RequestVerificationToken': tokenInput?.value ?? ''
                    },
                    body
                });

                const data = await response.json().catch(() => null);
                if (!response.ok) {
                    setStatus(data?.error || 'Could not read that image.', true);
                    return;
                }

                const extractedText = (data?.text || '').trim();
                if (!extractedText) {
                    setStatus('No readable text found.', true);
                    return;
                }

                textarea.value = textarea.value.trim()
                    ? `${textarea.value.trim()}\n\n${extractedText}`
                    : extractedText;
                textarea.focus();
                setStatus('Text added. Review it, then generate words.');
            } catch {
                setStatus('Could not upload the image.', true);
            } finally {
                scanButton.disabled = false;
                imageInput.value = '';
            }
        });
    })();

    (() => {
        const button = document.getElementById('bulkGenerateButton');
        if (!button) return;

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const generateUrl = '@Url.Action("Generate", "WordDetails")';
        const concurrency = 3;

        const setCardLoading = (card, loading) => {
            card.classList.toggle('loading', loading);
            const icon = card.querySelector('.word-icon .material-symbols-outlined');
            if (!icon) return;
            if (loading) {
                icon.dataset.defaultIcon ||= icon.textContent.trim() || 'translate';
                icon.textContent = 'progress_activity';
            } else {
                icon.textContent = icon.dataset.defaultIcon || 'translate';
            }
        };

        const generateOne = async (card) => {
            const id = card.dataset.wordDetailId;
            if (!id) return;
            setCardLoading(card, true);
            try {
                const response = await fetch(`${generateUrl}/${encodeURIComponent(id)}`, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'RequestVerificationToken': tokenInput?.value ?? ''
                    }
                });
                if (response.ok) {
                    const data = await response.json().catch(() => null);
                    if (data?.isEnriched) {
                        card.dataset.needsGeneration = 'false';
                    }
                }
            } catch {
                // Best-effort: leave the card as needs-generation so the user can retry.
            } finally {
                setCardLoading(card, false);
            }
        };

        const runQueue = async (cards) => {
            const queue = cards.slice();
            const updateLabel = () => {
                // needs-generation=true covers both queued and currently-loading cards;
                // failed cards stay flagged so they're still counted as remaining work.
                const remaining = document.querySelectorAll('.word-card[data-needs-generation="true"]').length;
                const inFlight = document.querySelectorAll('.word-card.loading').length;
                const label = button.querySelector('.bulk-generate-label');
                if (label) {
                    label.textContent = inFlight > 0
                        ? `Generating… (${remaining} left)`
                        : `Generate word details (${remaining})`;
                }
                if (remaining === 0 && inFlight === 0) {
                    button.hidden = true;
                }
            };

            const workers = Array.from({ length: Math.min(concurrency, queue.length) }, async () => {
                while (queue.length > 0) {
                    const card = queue.shift();
                    if (card) {
                        await generateOne(card);
                        updateLabel();
                    }
                }
            });
            await Promise.all(workers);
            button.disabled = false;
            updateLabel();
        };

        button.addEventListener('click', () => {
            const cards = Array.from(document.querySelectorAll('.word-card[data-needs-generation="true"]'));
            if (cards.length === 0) {
                button.hidden = true;
                return;
            }
            button.disabled = true;
            const label = button.querySelector('.bulk-generate-label');
            if (label) label.textContent = `Generating… (${cards.length} left)`;
            runQueue(cards);
        });
    })();

    (() => {
        const tabs = document.querySelectorAll('[data-tab]');
        const panels = {
            words: document.getElementById('wordsPanel'),
            sentences: document.getElementById('sentencesPanel')
        };
        const title = document.getElementById('collectionTitle');
        const subtitle = document.getElementById('collectionSubtitle');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const activeTab = tab.dataset.tab;
                tabs.forEach(item => {
                    const isActive = item === tab;
                    item.classList.toggle('active', isActive);
                    item.setAttribute('aria-selected', isActive.toString());
                });

                Object.entries(panels).forEach(([name, panel]) => {
                    if (panel) {
                        panel.hidden = name !== activeTab;
                    }
                });

                const activePanel = panels[activeTab];
                if (activePanel && title && subtitle) {
                    title.textContent = activePanel.dataset.title || "";
                    subtitle.textContent = activePanel.dataset.subtitle || "";
                }
            });
        });
    })();
</script>
}
