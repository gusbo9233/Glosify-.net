@model Glosify.Models.ViewModels.AssistantPanelViewModel
@inject Microsoft.Extensions.Options.IOptions<Glosify.Services.GeminiOptions> GeminiOptions
@{
    var imageInputId = $"assistantImageInput-{Model.QuizId:N}";
    var popoverId = $"assistantPopover-{Model.QuizId:N}";
    var currentAssistantModel = string.IsNullOrWhiteSpace(GeminiOptions.Value.AssistantModel)
        ? GeminiOptions.Value.StructuredModel
        : GeminiOptions.Value.AssistantModel;
    var hasGemini35AsCurrent = string.Equals(currentAssistantModel, "gemini-3.5-flash", StringComparison.OrdinalIgnoreCase);
}

<div class="assistant-float"
     data-assistant-panel
     data-quiz-id="@Model.QuizId"
     data-focused-word-id="@Model.FocusedWordId"
     data-document-id="@Model.DocumentId"
     data-current-page="@Model.CurrentPage">
    @Html.AntiForgeryToken()
    <button class="assistant-fab"
            type="button"
            aria-label="Open assistant"
            aria-controls="@popoverId"
            aria-expanded="false"
            data-assistant-toggle>
        <span class="material-symbols-outlined" aria-hidden="true">chat_bubble</span>
        <span class="assistant-fab-label">@Model.Title</span>
    </button>

    <section class="assistant-popover panel assistant-panel" id="@popoverId" hidden data-assistant-window>
        <div class="assistant-popover-header">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">smart_toy</span></div>
                <div>
                    <h2 class="panel-title">@Model.Title</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.ContextLabel))
                    {
                        <p class="assistant-context">@Model.ContextLabel</p>
                    }
                </div>
            </div>
            <button class="assistant-close" type="button" aria-label="Close assistant" data-assistant-close>
                <span class="material-symbols-outlined" aria-hidden="true">close</span>
            </button>
        </div>

        <div class="assistant-transcript" data-assistant-transcript>
            <div class="assistant-empty" data-assistant-empty>@Model.EmptyText</div>
        </div>

        <div class="assistant-status" data-assistant-status hidden></div>

        <form class="assistant-input" data-assistant-form>
            <div class="scan-toolbar">
                <label class="btn-scan-text" for="@imageInputId">
                    <span class="material-symbols-outlined" aria-hidden="true">photo_camera</span>
                    Picture
                </label>
                <label class="assistant-model-picker">
                    <span class="visually-hidden">Assistant model</span>
                    <select data-assistant-model-select aria-label="Assistant model">
                        <option value="@currentAssistantModel">Current (@currentAssistantModel)</option>
                        @if (!hasGemini35AsCurrent)
                        {
                            <option value="gemini-3.5-flash">Gemini 3.5 Flash</option>
                        }
                    </select>
                </label>
                <input
                    id="@imageInputId"
                    class="visually-hidden"
                    type="file"
                    accept="image/*"
                    capture="environment"
                    data-assistant-image-input
                    data-extract-url="@Url.Action("ExtractTextFromImage", "Quiz", new { quizId = Model.QuizId })" />
                <span class="scan-status" data-assistant-scan-status hidden></span>
            </div>
            <textarea
                class="form-textarea"
                data-assistant-textarea
                placeholder="@Model.Placeholder"
                rows="3"
                required></textarea>
            <div class="assistant-input-actions">
                <button class="btn-submit" type="submit" data-assistant-submit>
                    Send <span class="material-symbols-outlined" aria-hidden="true">send</span>
                </button>
            </div>
        </form>
    </section>
</div>
