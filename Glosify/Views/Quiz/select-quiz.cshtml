@model IEnumerable<Glosify.Models.Quiz>
@inject Glosify.Services.ILanguageContext LangContext
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Select Quiz";
    ViewData["ActiveNav"] = "quizzes";
    var currentLanguage = LangContext.CurrentLanguage ?? "";
}

@section Styles {
<style>
    .select-quiz-page {
        min-height: calc(100vh - 6rem);
        display: flex;
        flex-direction: column;
        gap: 32px;
        padding-bottom: 48px;
    }

    .select-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 24px;
    }

    .select-kicker {
        color: var(--primary);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .select-title {
        font-size: 40px;
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.05;
        margin: 0;
    }

    .select-subtitle {
        color: var(--on-surface-var);
        font-size: 15px;
        margin: 10px 0 0;
    }

    .btn-new-quiz {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
        background: var(--primary-container);
        color: var(--on-primary);
        border: none;
        border-radius: 9999px;
        padding: 14px 24px;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 12px 28px rgba(29, 185, 84, 0.18);
    }

    .btn-new-quiz:hover { transform: translateY(-1px); box-shadow: 0 16px 36px rgba(29, 185, 84, 0.24); }
    .btn-new-quiz:active { transform: scale(0.98); }

    .quiz-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 18px;
    }

    .quiz-card {
        min-height: 188px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: var(--surface);
        color: inherit;
        border: 1px solid rgba(61, 74, 61, 0.28);
        border-radius: 8px;
        padding: 24px;
        transition: transform 0.2s, border-color 0.2s, background 0.2s;
    }

    .quiz-card:hover {
        transform: translateY(-2px);
        background: var(--surface-high);
        border-color: rgba(83, 224, 118, 0.4);
    }

    .quiz-card-link {
        color: inherit;
        text-decoration: none;
    }

    .quiz-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .quiz-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: rgba(83, 224, 118, 0.1);
        color: var(--primary);
        border-radius: 8px;
    }

    .quiz-arrow {
        color: var(--on-surface-var);
        transition: color 0.2s, transform 0.2s;
    }

    .quiz-card:hover .quiz-arrow {
        color: var(--primary);
        transform: translateX(2px);
    }

    .quiz-name {
        font-size: 20px;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 20px 0 6px;
    }

    .quiz-languages {
        color: var(--on-surface-var);
        font-size: 14px;
        font-weight: 600;
    }

    .quiz-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 28px;
        color: rgba(188, 203, 185, 0.7);
        font-size: 12px;
        font-weight: 700;
    }

    .status-pill {
        color: var(--primary);
        background: rgba(83, 224, 118, 0.1);
        border-radius: 9999px;
        padding: 5px 10px;
    }

    .delete-form {
        margin: 18px 0 0;
    }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 36px;
        border: 1px solid rgba(255, 96, 96, 0.28);
        border-radius: 9999px;
        background: rgba(255, 96, 96, 0.08);
        color: #ffb4b4;
        cursor: pointer;
        font-size: 12px;
        font-weight: 800;
        padding: 0 12px;
    }

    .btn-delete .material-symbols-outlined {
        font-size: 18px;
    }

    .btn-delete:hover {
        background: rgba(255, 96, 96, 0.16);
        border-color: rgba(255, 96, 96, 0.48);
    }

    .page-message {
        border-radius: 8px;
        background: rgba(83, 224, 118, 0.12);
        color: var(--primary);
        font-size: 13px;
        font-weight: 750;
        padding: 12px 14px;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 360px;
        gap: 18px;
        text-align: center;
        background: var(--surface);
        border: 1px dashed rgba(83, 224, 118, 0.35);
        border-radius: 8px;
        padding: 48px 24px;
    }

    .empty-icon {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(83, 224, 118, 0.1);
        color: var(--primary);
        border-radius: 9999px;
    }

    .empty-title {
        font-size: 24px;
        font-weight: 850;
        margin: 0;
    }

    .empty-copy {
        color: var(--on-surface-var);
        max-width: 420px;
        margin: 0;
    }

    .modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 100;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(1, 14, 36, 0.82);
        backdrop-filter: blur(8px);
    }

    .modal-backdrop.open { display: flex; }

    .modal {
        width: 100%;
        max-width: 500px;
        background: var(--surface);
        border: 1px solid rgba(61, 74, 61, 0.35);
        border-radius: 8px;
        padding: 32px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
    }

    .modal-title {
        font-size: 24px;
        font-weight: 850;
        letter-spacing: -0.02em;
        margin: 0 0 24px;
    }

    .form-group { margin-bottom: 16px; }
    .form-label {
        display: block;
        color: var(--on-surface-var);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .form-input,
    .select-input {
        width: 100%;
        background: var(--surface-highest);
        color: var(--on-surface);
        border: none;
        border-radius: 9999px;
        padding: 13px 18px;
        font: inherit;
        outline: none;
    }

    .form-input:focus,
    .select-input:focus { box-shadow: 0 0 0 2px var(--primary); }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 28px;
    }

    .btn-cancel,
    .btn-create {
        border: none;
        border-radius: 9999px;
        padding: 12px 24px;
        font-weight: 800;
        cursor: pointer;
    }

    .btn-cancel { background: var(--surface-highest); color: var(--on-surface-var); }
    .btn-create { background: var(--primary-container); color: var(--on-primary); }

    @@media (max-width: 720px) {
        .select-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .select-title { font-size: 32px; }
        .btn-new-quiz { width: 100%; justify-content: center; }
    }
</style>
}

<section class="select-quiz-page">
    <header class="select-header">
        <div>
            <p class="select-kicker">Quiz Library · @currentLanguage</p>
            <h1 class="select-title">Select a quiz</h1>
            <p class="select-subtitle">Showing your @currentLanguage quizzes. <a asp-controller="Languages" asp-action="Index" style="color:var(--primary);text-decoration:none;font-weight:700;">Change language</a></p>
        </div>
        <button class="btn-new-quiz" type="button" onclick="document.getElementById('createModal').classList.add('open')">
            <span class="material-symbols-outlined">add</span>
            New Quiz
        </button>
    </header>

    @if (TempData["QuizMessage"] is string quizMessage)
    {
        <div class="page-message">@quizMessage</div>
    }

    @if (Model.Any())
    {
        <div class="quiz-grid">
            @foreach (var quiz in Model)
            {
                <article class="quiz-card">
                    <a class="quiz-card-link" asp-controller="Quiz" asp-action="Details" asp-route-id="@quiz.Id">
                        <div class="quiz-card-top">
                            <div class="quiz-icon"><span class="material-symbols-outlined">quiz</span></div>
                            <span class="material-symbols-outlined quiz-arrow">arrow_forward</span>
                        </div>
                        <h2 class="quiz-name">@quiz.Name</h2>
                        <p class="quiz-languages">@quiz.SourceLanguage &rarr; @quiz.TargetLanguage</p>
                    </a>
                    <div class="quiz-meta">
                        <span>@quiz.CreatedAt.ToString("MMM d, yyyy")</span>
                        <span class="status-pill">@quiz.ProcessingStatus</span>
                    </div>
                    <form class="delete-form" method="post" asp-controller="Quiz" asp-action="DeleteQuiz" asp-route-id="@quiz.Id" onsubmit="return confirm('Delete this quiz and all of its words?');">
                        @Html.AntiForgeryToken()
                        <button class="btn-delete" type="submit" aria-label="Delete @quiz.Name">
                            <span class="material-symbols-outlined">delete</span>
                            Delete
                        </button>
                    </form>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon"><span class="material-symbols-outlined">library_add</span></div>
            <h2 class="empty-title">No quizzes yet</h2>
            <p class="empty-copy">Create your first quiz to start building a vocabulary set.</p>
            <button class="btn-new-quiz" type="button" onclick="document.getElementById('createModal').classList.add('open')">
                <span class="material-symbols-outlined">add</span>
                Create Quiz
            </button>
        </div>
    }
</section>

<div class="modal-backdrop" id="createModal" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal">
        <h2 class="modal-title">Create New Quiz</h2>
        <form method="post" asp-controller="Quiz" asp-action="Create">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Quiz Name</label>
                <input class="form-input" type="text" name="Name" placeholder="e.g. French Basics" required />
            </div>
            <div class="form-group">
                <label class="form-label">Source Language</label>
                <select class="select-input" name="SourceLanguage" required>
                    <option value="">Select language...</option>
                    <option>English</option>
                    <option>Swedish</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Target Language</label>
                <input type="hidden" name="TargetLanguage" value="@currentLanguage" />
                <div class="form-input" style="display:flex;align-items:center;justify-content:space-between;cursor:default;">
                    <span>@currentLanguage</span>
                    <a asp-controller="Languages" asp-action="Index" style="color:var(--primary);text-decoration:none;font-size:12px;font-weight:700;">Change</a>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="document.getElementById('createModal').classList.remove('open')">Cancel</button>
                <button type="submit" class="btn-create">Create Quiz</button>
            </div>
        </form>
    </div>
</div>
