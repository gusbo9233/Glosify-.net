@model ClassroomDetailsViewModel

<section>
    <div class="collection-header">
        <div>
            <h2 class="collection-title">Quiz results</h2>
            <p class="collection-subtitle">@Model.Results.Count @(Model.Results.Count == 1 ? "attempt" : "attempts") from classroom practice</p>
        </div>
    </div>

    @if (Model.Results.Any())
    {
        <div class="classroom-results-table-wrap">
            <table class="admin-credit-table">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Quiz</th>
                        <th>Mode</th>
                        <th>Score</th>
                        <th>Correct</th>
                        <th>Completed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Results)
                    {
                        var answered = row.CorrectCount + row.IncorrectCount;
                        var score = answered == 0 ? 0 : (int)Math.Round(row.CorrectCount * 100d / answered);
                        <tr>
                            <td>
                                <a asp-controller="Classroom" asp-action="MemberResults" asp-route-id="@Model.Classroom.Id" asp-route-memberId="@row.UserId">@row.MemberName</a>
                            </td>
                            <td>@row.QuizName</td>
                            <td>@row.Mode</td>
                            <td>@score%</td>
                            <td>@row.CorrectCount / @row.TotalItems</td>
                            <td>@row.CompletedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">No attempts yet. Results appear when members practice quizzes from the Content tab.</div>
    }
</section>
