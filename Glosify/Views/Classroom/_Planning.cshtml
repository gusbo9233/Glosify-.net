@model ClassroomDetailsViewModel
@{
    var sharedQuizzes = Model.Content
        .Where(c => c.ContentType == ClassroomContentType.Quiz && c.Quiz != null)
        .Select(c => c.Quiz!)
        .ToList();
}

@if (Model.IsTeacher)
{
    <div class="tool-grid">
        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">event</span></div>
                <h2 class="panel-title">Add a lesson</h2>
            </div>
            <form method="post" asp-controller="Classroom" asp-action="CreateLesson">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Classroom.Id" />
                <div class="form-group">
                    <label class="form-label" for="lessonTitle">Title</label>
                    <input class="form-input" id="lessonTitle" name="title" maxlength="160" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="lessonDescription">Description (optional)</label>
                    <input class="form-input" id="lessonDescription" name="description" maxlength="2000" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="lessonScheduledAt">Scheduled for (optional)</label>
                    <input class="form-input" id="lessonScheduledAt" name="scheduledAt" type="datetime-local" />
                </div>
                <button class="btn-submit" type="submit">
                    Add lesson <span class="material-symbols-outlined" aria-hidden="true">event</span>
                </button>
            </form>
        </section>

        <section class="panel">
            <div class="panel-header">
                <div class="panel-icon"><span class="material-symbols-outlined">assignment</span></div>
                <h2 class="panel-title">Add an assignment</h2>
            </div>
            <form method="post" asp-controller="Classroom" asp-action="CreateAssignment">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Classroom.Id" />
                <div class="form-group">
                    <label class="form-label" for="assignmentTitle">Title</label>
                    <input class="form-input" id="assignmentTitle" name="title" maxlength="160" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="assignmentInstructions">Instructions (optional)</label>
                    <input class="form-input" id="assignmentInstructions" name="instructions" maxlength="2000" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="assignmentQuiz">Quiz (optional, from shared content)</label>
                    <select class="form-input" id="assignmentQuiz" name="quizId">
                        <option value="">No quiz</option>
                        @foreach (var quiz in sharedQuizzes)
                        {
                            <option value="@quiz.Id">@quiz.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="assignmentLesson">Lesson (optional)</label>
                    <select class="form-input" id="assignmentLesson" name="lessonId">
                        <option value="">No lesson</option>
                        @foreach (var lessonInfo in Model.Schedule.Lessons)
                        {
                            <option value="@lessonInfo.Lesson.Id">@lessonInfo.Lesson.Title</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="assignmentDueAt">Due (optional)</label>
                    <input class="form-input" id="assignmentDueAt" name="dueAt" type="datetime-local" />
                </div>
                <button class="btn-submit" type="submit">
                    Add assignment <span class="material-symbols-outlined" aria-hidden="true">assignment_add</span>
                </button>
            </form>
        </section>
    </div>
}

<section>
    <div class="collection-header">
        <div>
            <h2 class="collection-title">Course plan</h2>
            <p class="collection-subtitle">
                @Model.Schedule.Lessons.Count @(Model.Schedule.Lessons.Count == 1 ? "lesson" : "lessons"),
                @(Model.Schedule.Lessons.Sum(l => l.Assignments.Count) + Model.Schedule.UnattachedAssignments.Count) assignments
            </p>
        </div>
    </div>

    @foreach (var lessonInfo in Model.Schedule.Lessons)
    {
        <section class="classroom-lesson">
            <div class="classroom-lesson-header">
                <div>
                    <h3 class="collection-title">@lessonInfo.Lesson.Title</h3>
                    <p class="book-meta">
                        @if (lessonInfo.Lesson.ScheduledAt.HasValue)
                        {
                            @lessonInfo.Lesson.ScheduledAt.Value.ToLocalTime().ToString("dddd MMM d, yyyy HH:mm")
                        }
                        @if (!string.IsNullOrWhiteSpace(lessonInfo.Lesson.Description))
                        {
                            <span> &middot; @lessonInfo.Lesson.Description</span>
                        }
                    </p>
                </div>
                @if (Model.IsTeacher)
                {
                    <form method="post" asp-controller="Classroom" asp-action="DeleteLesson" data-confirm="Delete this lesson? Its assignments stay, unattached.">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Classroom.Id" />
                        <input type="hidden" name="lessonId" value="@lessonInfo.Lesson.Id" />
                        <button class="btn-linkish" type="submit">Delete lesson</button>
                    </form>
                }
            </div>
            <div class="classroom-member-list">
                @foreach (var info in lessonInfo.Assignments)
                {
                    <partial name="_PlanningAssignment" model="(Model, info)" />
                }
                @if (!lessonInfo.Assignments.Any())
                {
                    <div class="empty-state">No assignments for this lesson.</div>
                }
            </div>
        </section>
    }

    @if (Model.Schedule.UnattachedAssignments.Any())
    {
        <section class="classroom-lesson">
            <div class="classroom-lesson-header">
                <h3 class="collection-title">Other assignments</h3>
            </div>
            <div class="classroom-member-list">
                @foreach (var info in Model.Schedule.UnattachedAssignments)
                {
                    <partial name="_PlanningAssignment" model="(Model, info)" />
                }
            </div>
        </section>
    }

    @if (!Model.Schedule.Lessons.Any() && !Model.Schedule.UnattachedAssignments.Any())
    {
        <div class="empty-state">No lessons or assignments yet. @(Model.IsTeacher ? "Plan the course above." : "Your teacher hasn't planned anything yet.")</div>
    }
</section>
