@model FlashcardQuizViewModel

<div class="progress-wrap">
    <div class="progress-meta">
        <span class="progress-count">@Model.CompletedCards of @Model.TotalCards @Model.ItemPluralLabel</span>
        <span class="progress-count">@Model.RememberedCount remembered</span>
    </div>
    <div class="progress-track" aria-hidden="true">
        <div class="progress-fill" style="width:@Model.ProgressPercent%"></div>
    </div>
</div>

<div class="card-stage">
    @if (Model.IsComplete)
    {
        <section class="results visible" aria-live="polite">
            <div class="result-score">@Model.ScorePercent%</div>
            <h2 class="flash-title">Session Complete</h2>
            <div class="result-grid">
                <div class="result-stat"><span>Remembered</span><span>@Model.RememberedCount</span></div>
                <div class="result-stat"><span>Review Again</span><span>@Model.AgainCount</span></div>
                <div class="result-stat"><span>Skipped</span><span>@Model.SkippedCount</span></div>
            </div>
            <form method="post" asp-controller="FlashcardQuiz" asp-action="Restart">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quizId" value="@Model.QuizId" />
                <input type="hidden" name="wordCount" value="@Model.WordCount" />
                <input type="hidden" name="practiceDirection" value="@Model.PracticeDirection" />
                <input type="hidden" name="practiceItemType" value="@Model.PracticeItemType" />
                <button class="btn-main" type="submit">Restart Session</button>
            </form>
            @if (Model.AgainCount > 0)
            {
                <form method="post" asp-controller="FlashcardQuiz" asp-action="RestartAgain">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.SessionId" />
                    <button class="btn-main" type="submit">Practice Again</button>
                </form>
            }
            
        </section>
    }
    else if (Model.CurrentCard != null)
    {
        @if (Model.IsAnswerRevealed)
        {
            <article class="flashcard is-revealed" aria-live="polite">
                <span class="card-label">@Model.CardLabel @Model.CurrentCardNumber</span>
                <h2 class="card-word">@Model.CurrentCard.Prompt</h2>
                <div class="card-answer revealed">
                    <div class="translation">@Model.CurrentCard.Answer</div>
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentCard.ExampleSentence))
                    {
                        <div class="example">@Model.CurrentCard.ExampleSentence</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentCard.ExampleTranslation))
                    {
                        <div class="example">@Model.CurrentCard.ExampleTranslation</div>
                    }
                </div>
            </article>
        }
        else
        {
            <form class="card-reveal-form" method="post" asp-controller="FlashcardQuiz" asp-action="Reveal" data-flashcard-form data-card-reveal-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@Model.SessionId" />
                <button class="flashcard flashcard-clickable" type="submit" aria-label="Reveal answer for @Model.CurrentCard.Prompt">
                    <span class="card-label">@Model.CardLabel @Model.CurrentCardNumber</span>
                    <span class="card-word">@Model.CurrentCard.Prompt</span>
                </button>
            </form>
        }

        @if (Model.IsAnswerRevealed)
        {
            <form class="controls" method="post" asp-controller="FlashcardQuiz" asp-action="Rate" data-flashcard-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@Model.SessionId" />
                <div class="rating-row revealed">
                    <button class="btn-rating again" type="submit" name="rating" value="again">Again</button>
                    <button class="btn-rating" type="submit" name="rating" value="good">Good</button>
                    <button class="btn-rating easy" type="submit" name="rating" value="easy">Easy</button>
                </div>
                <p class="swipe-hint" aria-hidden="true">Swipe right for Good, left for Again</p>
                <button class="btn-linkish" type="submit" name="rating" value="skip">Skip</button>
            </form>
        }
        else
        {
            <div class="controls">
                <form method="post" asp-controller="FlashcardQuiz" asp-action="Reveal" data-flashcard-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.SessionId" />
                    <button class="btn-main" type="submit">Show Answer</button>
                </form>
                <form method="post" asp-controller="FlashcardQuiz" asp-action="Rate" data-flashcard-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.SessionId" />
                    <button class="btn-linkish" type="submit" name="rating" value="skip">Skip</button>
                </form>
            </div>
        }

        <form class="session-reset" method="post" asp-controller="FlashcardQuiz" asp-action="Restart">
            @Html.AntiForgeryToken()
            <input type="hidden" name="quizId" value="@Model.QuizId" />
            <input type="hidden" name="wordCount" value="@Model.WordCount" />
            <input type="hidden" name="practiceDirection" value="@Model.PracticeDirection" />
            <input type="hidden" name="practiceItemType" value="@Model.PracticeItemType" />
            <button class="btn-linkish" type="submit">Reset Session</button>
        </form>
    }
    else
    {
        <div class="empty-state">
            <h2 class="flash-title">No @Model.ItemPluralLabel yet</h2>
            <p class="flash-subtitle">Add @Model.ItemPluralLabel to a quiz, then start a flashcard session from that quiz.</p>
            <button class="btn-main" type="button" disabled>Show Answer</button>
        </div>
    }
</div>
