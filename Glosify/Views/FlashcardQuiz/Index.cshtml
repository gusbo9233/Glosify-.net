@model FlashcardQuizViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Flashcard Quiz";
    ViewData["ActiveNav"] = "quizzes";

    var quizName = Model.SelectedQuiz?.Name ?? "Flashcard Quiz";
}

<section class="flash-shell" data-flashcard-quiz>
    <header class="flash-header">
        <div>
            <p class="flash-kicker">@Model.DirectionLabel</p>
            <h1 class="flash-title">@quizName</h1>
            <p class="flash-subtitle">Reveal the answer, rate recall, and keep moving.</p>
        </div>
        @if (Model.SelectedQuiz != null)
        {
            <a asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.SelectedQuiz.Id" class="btn-linkish">Back to words</a>
        }
    </header>

    <div id="flashcardSession" data-flashcard-session>
        @await Html.PartialAsync("_FlashcardSession", Model)
    </div>
</section>

@section Scripts {
<script src="~/js/flashcard-quiz.js" asp-append-version="true"></script>
}
