@model ErrorViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = Model.Title;
}

<section class="service-warmup">
    <div class="service-warmup-icon">
        <span class="material-symbols-outlined" aria-hidden="true">hourglass_top</span>
    </div>
    <p class="hero-label">Temporary startup delay</p>
    <h1 class="service-warmup-title">@Model.Title</h1>
    <p class="service-warmup-message">@Model.Message</p>

    @if (Model.IsServiceWarmup)
    {
        <a class="btn-hero" href="@(Model.ReturnPath ?? Context.Request.Path)">Try again</a>
    }
</section>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}
