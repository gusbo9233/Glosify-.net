@inject Glosify.Services.ILanguageContext LangContext
@using System.Security.Claims
@using Microsoft.AspNetCore.Html
@functions {
    string CurrentController => (ViewContext.RouteData.Values["controller"] as string ?? "").ToLowerInvariant();
    string CurrentAction => (ViewContext.RouteData.Values["action"] as string ?? "").ToLowerInvariant();
    string DisplayAccount => User.FindFirstValue(ClaimTypes.Email)
        ?? User.Identity?.Name
        ?? "Signed in";

    bool IsActive(string controller, string action) =>
        CurrentController == controller.ToLowerInvariant() && CurrentAction == action.ToLowerInvariant();

    bool IsQuizzesActive() =>
        CurrentController == "quiz"
        || CurrentController == "quizzes"
        || CurrentController == "flashcardquiz";

    string NavClass(string controller, string action = "Index") => IsActive(controller, action)
        ? "text-[#1DB954] font-bold border-l-4 border-[#1DB954] pl-4 flex items-center gap-x-4 transition-colors duration-300"
        : "text-slate-400 font-medium pl-4 hover:text-white flex items-center gap-x-4 transition-colors duration-300";

    string IconClass(string controller, string action = "Index") =>
        IsActive(controller, action) ? " material-symbols-filled" : "";

    string QuizzesNavClass() => IsQuizzesActive()
        ? "text-[#1DB954] font-bold border-l-4 border-[#1DB954] pl-4 flex items-center gap-x-4 transition-colors duration-300"
        : "text-slate-400 font-medium pl-4 hover:text-white flex items-center gap-x-4 transition-colors duration-300";

    string QuizzesIconClass() => IsQuizzesActive() ? " material-symbols-filled" : "";

    IHtmlContent NavIcon(string name)
    {
        var paths = name switch
        {
            "language" => """
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M3 12h18"></path>
                <path d="M12 3a13 13 0 0 1 0 18"></path>
                <path d="M12 3a13 13 0 0 0 0 18"></path>
                """,
            "home" => """
                <path d="M3 10.5 12 3l9 7.5"></path>
                <path d="M5 9.5V21h14V9.5"></path>
                <path d="M9 21v-6h6v6"></path>
                """,
            "explore" => """
                <circle cx="12" cy="12" r="9"></circle>
                <path d="m15.5 8.5-2.2 4.8-4.8 2.2 2.2-4.8 4.8-2.2Z"></path>
                """,
            "menu_book" => """
                <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H7a3 3 0 0 0-3 3V5.5Z"></path>
                <path d="M4 5.5V22"></path>
                <path d="M8 7h8"></path>
                <path d="M8 11h7"></path>
                """,
            "fitness_center" => """
                <path d="M6.5 6.5 17.5 17.5"></path>
                <path d="m4 9 5-5"></path>
                <path d="m15 20 5-5"></path>
                <path d="M2.5 6.5 6.5 2.5"></path>
                <path d="m17.5 21.5 4-4"></path>
                """,
            "subscriptions" => """
                <rect x="4" y="7" width="16" height="12" rx="2"></rect>
                <path d="M8 3h8"></path>
                <path d="m10 11 5 2.5-5 2.5v-5Z"></path>
                """,
            "quiz" => """
                <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14l-4-3H6a2 2 0 0 1-2-2V5Z"></path>
                <path d="M9.5 8.5a2.5 2.5 0 0 1 5 0c0 2-2.5 2-2.5 4"></path>
                <path d="M12 16h.01"></path>
                """,
            _ => """
                <circle cx="12" cy="12" r="9"></circle>
                """
        };

        return new HtmlString($"""
            <svg class="nav-svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {paths}
            </svg>
            """);
    }
}
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Glosify</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary-fixed-variant": "#881d28",
                        "on-tertiary-fixed": "#400009",
                        "error-container": "#93000a",
                        "on-error-container": "#ffdad6",
                        "surface-container-highest": "#27354c",
                        "surface-dim": "#041329",
                        "outline-variant": "#3d4a3d",
                        "primary-fixed-dim": "#53e076",
                        "outline": "#869585",
                        "tertiary-fixed": "#ffdad9",
                        "on-tertiary": "#680114",
                        "on-primary-fixed-variant": "#005320",
                        "surface-container-lowest": "#010e24",
                        "secondary-fixed-dim": "#99d59d",
                        "surface-bright": "#2c3951",
                        "primary": "#53e076",
                        "error": "#ffb4ab",
                        "surface-container-low": "#0d1c32",
                        "on-primary-fixed": "#002108",
                        "on-secondary-fixed": "#002108",
                        "tertiary-container": "#ff767b",
                        "on-secondary-fixed-variant": "#195127",
                        "primary-container": "#1db954",
                        "surface-container-high": "#1c2a41",
                        "on-secondary-container": "#8cc690",
                        "background": "#041329",
                        "on-surface": "#d6e3ff",
                        "inverse-on-surface": "#233148",
                        "secondary-container": "#1c5329",
                        "on-primary": "#003914",
                        "primary-fixed": "#72fe8f",
                        "surface-tint": "#53e076",
                        "secondary": "#99d59d",
                        "surface-container": "#112036",
                        "surface": "#041329",
                        "on-background": "#d6e3ff",
                        "tertiary-fixed-dim": "#ffb3b3",
                        "inverse-primary": "#006e2d",
                        "on-primary-container": "#004118",
                        "inverse-surface": "#d6e3ff",
                        "on-error": "#690005",
                        "on-surface-variant": "#bccbb9",
                        "surface-variant": "#27354c",
                        "on-secondary": "#003914",
                        "secondary-fixed": "#b5f1b8",
                        "tertiary": "#ffb3b3",
                        "on-tertiary-container": "#730a1b"
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Plus Jakarta Sans"],
                        "label": ["Plus Jakarta Sans"]
                    }
                }
            }
        }
    </script>
    <style>
        body.app-layout-body {
            display: block;
            margin: 0;
            overflow-x: hidden;
            overflow-y: auto;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #041329;
        }

        .app-layout-body .material-symbols-outlined {
            font-family: 'Material Symbols Outlined';
            font-weight: normal;
            font-style: normal;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
            font-feature-settings: 'liga';
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .app-layout-body .nav-svg-icon {
            width: 24px;
            height: 24px;
            flex: 0 0 24px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="app-layout-body text-on-surface selection:bg-primary selection:text-on-primary overflow-x-hidden">
    <!-- SideNavBar -->
    <aside class="h-full w-64 fixed left-0 top-0 hidden md:flex flex-col bg-[#041329] dark:bg-[#041329] font-['Plus_Jakarta_Sans'] text-sm tracking-tight z-50">
        <div class="flex flex-col gap-y-6 py-8 px-6 h-full">
            <div class="mb-8">
                <span class="text-2xl font-bold tracking-tighter text-[#1DB954]">Sonic Polyglot</span>
                <p class="text-slate-400 text-xs mt-1">Premium Learner</p>
                @if (!string.IsNullOrEmpty(LangContext.CurrentLanguage))
                {
                    <a asp-controller="Languages" asp-action="Index"
                       class="language-context-pill language-context-pill-active inline-flex items-center gap-x-2 mt-3 px-3 py-1.5 rounded-full text-xs font-bold">
                        <span class="material-symbols-outlined language-context-icon">translate</span>
                        @LangContext.CurrentLanguage
                    </a>
                }
                else
                {
                    <a asp-controller="Languages" asp-action="Index"
                       class="language-context-pill language-context-pill-empty inline-flex items-center gap-x-2 mt-3 px-3 py-1.5 rounded-full text-xs font-bold">
                        <span class="material-symbols-outlined language-context-icon">translate</span>
                        Pick a language
                    </a>
                }
            </div>
            <nav class="flex flex-col gap-y-4">
                <a class="@NavClass("Languages")" asp-controller="Languages" asp-action="Index">
                    @NavIcon("language")
                    Language selector
                </a>
                <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home")
                    Home
                </a>
                <a class="@NavClass("Explore")" asp-controller="Explore" asp-action="Index">
                    @NavIcon("explore")
                    Explore
                </a>
                <a class="@NavClass("Dictionary")" asp-controller="Dictionary" asp-action="Index">
                    @NavIcon("menu_book")
                    Dictionary
                </a>
                <a class="@NavClass("Practice")" asp-controller="Practice" asp-action="Index">
                    @NavIcon("fitness_center")
                    Practice
                </a>
                <a class="@NavClass("Library")" asp-controller="Library" asp-action="Index">
                    @NavIcon("subscriptions")
                    Library
                </a>
                <a class="@QuizzesNavClass()" asp-controller="Quiz" asp-action="Index">
                    @NavIcon("quiz")
                    Quizzes
                </a>
            </nav>
            <div class="mt-auto">
                <button class="w-full py-4 bg-primary-container text-on-primary font-bold rounded-full hover:scale-105 transition-transform">
                    Start New Unit
                </button>
            </div>
        </div>
    </aside>
    <!-- Main Content Area -->
    <main class="md:ml-64 min-h-screen">
        <!-- TopNavBar -->
        <header class="fixed top-0 right-0 w-full md:w-[calc(100%-16rem)] z-40 bg-[#041329]/80 dark:bg-[#041329]/80 backdrop-blur-xl font-['Plus_Jakarta_Sans'] font-semibold">
            <div class="flex justify-between items-center px-8 h-16">
                <div class="flex items-center gap-x-4 flex-1">
                    <div class="bg-surface-container-high rounded-full px-4 py-2 flex items-center gap-x-3 w-full max-w-md">
                        <span class="material-symbols-outlined text-slate-400">search</span>
                        <input class="bg-transparent border-none focus:ring-0 text-sm text-on-surface w-full" placeholder="What do you want to learn?" type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-x-4">
                    <button class="hover:bg-[#112036] rounded-full p-2 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-slate-300">notifications</span>
                    </button>
                    <button class="hover:bg-[#112036] rounded-full p-2 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-slate-300">settings</span>
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="flex items-center gap-x-3 min-w-0">
                            <div class="hidden lg:flex flex-col items-end min-w-0">
                                <span class="text-xs uppercase tracking-widest text-slate-500">Signed in as</span>
                                <span class="text-sm text-on-surface max-w-56 truncate">@DisplayAccount</span>
                            </div>
                            <div class="w-9 h-9 rounded-full bg-surface-container-highest text-primary flex items-center justify-center shrink-0" title="@DisplayAccount">
                                <span class="material-symbols-outlined text-xl">account_circle</span>
                            </div>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="inline-flex items-center justify-center w-9 h-9 rounded-full hover:bg-[#112036] transition-all active:scale-95"
                                        title="Log out"
                                        aria-label="Log out">
                                    <span class="material-symbols-outlined text-slate-300 text-xl">logout</span>
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="inline-flex items-center gap-x-2 px-4 py-2 rounded-full bg-primary-container text-on-primary text-sm font-bold no-underline">
                            <span class="material-symbols-outlined text-xl">login</span>
                            Log in
                        </a>
                    }
                </div>
            </div>
        </header>
        <!-- Canvas -->
        <div class="pt-24 px-8 max-w-7xl mx-auto">
            @RenderBody()
        </div>
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
