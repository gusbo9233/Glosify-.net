@inject Glosify.Services.ILanguageContext LangContext
@using System.Security.Claims
@using Microsoft.AspNetCore.Html
@functions {
    string CurrentController => (ViewContext.RouteData.Values["controller"] as string ?? "").ToLowerInvariant();
    string CurrentAction => (ViewContext.RouteData.Values["action"] as string ?? "").ToLowerInvariant();
    string DisplayAccount => User.FindFirstValue(ClaimTypes.Email)
        ?? User.Identity?.Name
        ?? "Signed in";

    bool IsActive(string controller, string action) =>
        CurrentController == controller.ToLowerInvariant() && CurrentAction == action.ToLowerInvariant();

    bool IsQuizzesActive() =>
        CurrentController == "quiz"
        || CurrentController == "quizzes"
        || CurrentController == "flashcardquiz";

    string NavClass(string controller, string action = "Index") =>
        IsActive(controller, action) ? "app-nav-item is-active" : "app-nav-item";

    string QuizzesNavClass() =>
        IsQuizzesActive() ? "app-nav-item is-active" : "app-nav-item";

    IHtmlContent NavIcon(string name)
    {
        var paths = name switch
        {
            "language" => """
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M3 12h18"></path>
                <path d="M12 3a13 13 0 0 1 0 18"></path>
                <path d="M12 3a13 13 0 0 0 0 18"></path>
                """,
            "home" => """
                <path d="M3 10.5 12 3l9 7.5"></path>
                <path d="M5 9.5V21h14V9.5"></path>
                <path d="M9 21v-6h6v6"></path>
                """,
            "explore" => """
                <circle cx="12" cy="12" r="9"></circle>
                <path d="m15.5 8.5-2.2 4.8-4.8 2.2 2.2-4.8 4.8-2.2Z"></path>
                """,
            "menu_book" => """
                <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H7a3 3 0 0 0-3 3V5.5Z"></path>
                <path d="M4 5.5V22"></path>
                <path d="M8 7h8"></path>
                <path d="M8 11h7"></path>
                """,
            "fitness_center" => """
                <path d="M6.5 6.5 17.5 17.5"></path>
                <path d="m4 9 5-5"></path>
                <path d="m15 20 5-5"></path>
                <path d="M2.5 6.5 6.5 2.5"></path>
                <path d="m17.5 21.5 4-4"></path>
                """,
            "subscriptions" => """
                <rect x="4" y="7" width="16" height="12" rx="2"></rect>
                <path d="M8 3h8"></path>
                <path d="m10 11 5 2.5-5 2.5v-5Z"></path>
                """,
            "quiz" => """
                <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14l-4-3H6a2 2 0 0 1-2-2V5Z"></path>
                <path d="M9.5 8.5a2.5 2.5 0 0 1 5 0c0 2-2.5 2-2.5 4"></path>
                <path d="M12 16h.01"></path>
                """,
            _ => """
                <circle cx="12" cy="12" r="9"></circle>
                """
        };

        return new HtmlString($"""
            <svg class="nav-svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {paths}
            </svg>
            """);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Glosify</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,400..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="app-body">
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="app-sidebar-brand">
                <h1 class="wordmark">Glosiglot</h1>
                <p class="brand-tier">Premium Learner</p>
                @if (!string.IsNullOrEmpty(LangContext.CurrentLanguage))
                {
                    <a asp-controller="Languages" asp-action="Index"
                       class="language-context-pill language-context-pill-active">
                        <span class="material-symbols-outlined language-context-icon">translate</span>
                        @LangContext.CurrentLanguage
                    </a>
                }
                else
                {
                    <a asp-controller="Languages" asp-action="Index"
                       class="language-context-pill language-context-pill-empty">
                        <span class="material-symbols-outlined language-context-icon">translate</span>
                        Pick a language
                    </a>
                }
            </div>

            <nav class="app-nav">
                <a class="@NavClass("Languages")" asp-controller="Languages" asp-action="Index">
                    @NavIcon("language")
                    Language selector
                </a>
                <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home")
                    Home
                </a>
                <a class="@NavClass("Explore")" asp-controller="Explore" asp-action="Index">
                    @NavIcon("explore")
                    Explore
                </a>
                <a class="@NavClass("Dictionary")" asp-controller="Dictionary" asp-action="Index">
                    @NavIcon("menu_book")
                    Dictionary
                </a>
                <a class="@NavClass("Practice")" asp-controller="Practice" asp-action="Index">
                    @NavIcon("fitness_center")
                    Practice
                </a>
                <a class="@NavClass("Library")" asp-controller="Library" asp-action="Index">
                    @NavIcon("subscriptions")
                    Library
                </a>
                <a class="@QuizzesNavClass()" asp-controller="Quiz" asp-action="Index">
                    @NavIcon("quiz")
                    Quizzes
                </a>
            </nav>

            <button type="button" class="app-sidebar-cta">Start New Unit</button>
        </aside>

        <main class="app-main">
            <header class="app-topbar">
                <a class="app-mobile-brand" asp-controller="Home" asp-action="Index" aria-label="Glosify home">
                    Glosiglot
                </a>
                <div class="app-search">
                    <span class="material-symbols-outlined">search</span>
                    <input placeholder="What do you want to learn?" type="text" />
                </div>
                <div class="app-topbar-right">
                    <button type="button" class="icon-button" aria-label="Notifications">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <button type="button" class="icon-button" aria-label="Settings">
                        <span class="material-symbols-outlined">settings</span>
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="account-block">
                            <div class="account-meta">
                                <span class="account-meta-eyebrow">Signed in as</span>
                                <span class="account-meta-email">@DisplayAccount</span>
                            </div>
                            <div class="account-avatar" title="@DisplayAccount">
                                <span class="material-symbols-outlined">account_circle</span>
                            </div>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="btn-social-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="icon-button" title="Log out" aria-label="Log out">
                                    <span class="material-symbols-outlined">logout</span>
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn-login">
                            <span class="material-symbols-outlined">login</span>
                            Log in
                        </a>
                    }
                </div>
            </header>

            <div class="app-canvas">
                @RenderBody()
            </div>
        </main>
    </div>
    <nav class="app-mobile-nav" aria-label="Primary navigation">
        <a class="@NavClass("Languages")" asp-controller="Languages" asp-action="Index">
            @NavIcon("language")
            <span>Language</span>
        </a>
        <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
            @NavIcon("home")
            <span>Home</span>
        </a>
        <a class="@QuizzesNavClass()" asp-controller="Quiz" asp-action="Index">
            @NavIcon("quiz")
            <span>Quizzes</span>
        </a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="@NavClass("Account")" asp-controller="Account" asp-action="Login">
                <span class="material-symbols-outlined">account_circle</span>
                <span>Account</span>
            </a>
        }
        else
        {
            <a class="@NavClass("Account", "Login")" asp-controller="Account" asp-action="Login">
                <span class="material-symbols-outlined">login</span>
                <span>Log in</span>
            </a>
        }
    </nav>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
