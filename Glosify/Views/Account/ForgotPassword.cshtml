@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<main class="auth-shell">
    <div class="brand-stack">
        <div class="brand-orb">
            <span class="material-symbols-outlined">graphic_eq</span>
        </div>
        <h1>Glosify</h1>
        <p class="brand-tagline">Sonic Language Immersion</p>
    </div>

    <section class="glass-card is-centered">
        <span class="material-symbols-outlined auth-icon-hero">lock_reset</span>
        <header class="auth-card-header">
            <h2>Password Reset</h2>
            <p>Password reset is not yet configured. Please contact support or create a new account.</p>
        </header>
        <a class="back-to-login" asp-controller="Account" asp-action="Login">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to Login
        </a>
    </section>
</main>
