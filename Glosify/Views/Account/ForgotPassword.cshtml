@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<main class="w-full max-w-[480px] z-10">
    <div class="flex flex-col items-center mb-10">
        <div class="w-16 h-16 bg-primary-container rounded-lg flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(29,185,84,0.3)]">
            <span class="material-symbols-outlined text-on-primary-container text-4xl">graphic_eq</span>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tighter text-on-background mb-2">Glosify</h1>
        <p class="text-slate-400 font-medium tracking-tight">Sonic Language Immersion</p>
    </div>

    <div class="glass-effect rounded-xl p-8 md:p-12 border border-white/5 shadow-2xl text-center">
        <span class="material-symbols-outlined text-primary text-5xl mb-4 block">lock_reset</span>
        <h2 class="text-2xl font-bold text-white mb-3">Password Reset</h2>
        <p class="text-slate-400 text-sm mb-8">Password reset is not yet configured. Please contact support or create a new account.</p>
        <a asp-controller="Account" asp-action="Login"
           class="inline-flex items-center gap-2 text-primary font-bold hover:underline">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Login
        </a>
    </div>
</main>
