@model Glosify.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "/";
}

<main class="w-full max-w-[480px] z-10">
    <!-- Brand Identity -->
    <div class="flex flex-col items-center mb-10">
        <div class="w-16 h-16 bg-primary-container rounded-lg flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(29,185,84,0.3)]">
            <span class="material-symbols-outlined text-on-primary-container text-4xl">graphic_eq</span>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tighter text-on-background mb-2">Glosify</h1>
        <p class="text-slate-400 font-medium tracking-tight">Sonic Language Immersion</p>
    </div>

    <!-- Login Card -->
    <div class="glass-effect rounded-xl p-8 md:p-12 border border-white/5 shadow-2xl">
        <header class="mb-10">
            <h2 class="text-2xl font-bold text-white mb-2">Welcome Back</h2>
            <p class="text-slate-400 text-sm">Please enter your details to resume your journey.</p>
        </header>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 rounded-md bg-error/10 border border-error/30 px-4 py-3 text-sm text-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- Email Field -->
            <div class="space-y-2">
                <label asp-for="Email" class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1">Email Address</label>
                <input asp-for="Email" type="email"
                       class="w-full bg-surface-container-lowest border-none rounded-md py-4 px-5 text-on-surface placeholder:text-slate-500 focus:ring-2 focus:ring-primary-container transition-all"
                       placeholder="name@domain.com" autocomplete="email" />
            </div>

            <!-- Password Field -->
            <div class="space-y-2">
                <div class="flex justify-between items-center px-1">
                    <label asp-for="Password" class="text-xs font-bold uppercase tracking-widest text-slate-400">Password</label>
                    <a asp-controller="Account" asp-action="ForgotPassword"
                       class="text-xs font-bold text-primary hover:text-primary-fixed-dim transition-colors">Forgot?</a>
                </div>
                <input asp-for="Password" type="password"
                       class="w-full bg-surface-container-lowest border-none rounded-md py-4 px-5 text-on-surface placeholder:text-slate-500 focus:ring-2 focus:ring-primary-container transition-all"
                       placeholder="••••••••" autocomplete="current-password" />
            </div>

            <!-- Login Button -->
            <button type="submit"
                    class="w-full bg-primary-container text-on-primary font-bold py-4 rounded-full hover:scale-[1.02] active:scale-[0.98] transition-all shadow-[0_10px_30px_rgba(29,185,84,0.2)] flex items-center justify-center gap-2">
                Log In
                <span class="material-symbols-outlined text-xl">arrow_forward</span>
            </button>
        </form>

        <!-- Divider -->
        <div class="relative my-10" role="separator">
            <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-white/10"></div>
            </div>
            <div class="relative flex justify-center text-xs uppercase tracking-widest">
                <span class="bg-[#1e2a3f] px-4 text-slate-500 font-bold">Or continue with</span>
            </div>
        </div>

        <!-- Social Logins -->
        <div class="space-y-4">
            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="provider" value="Google" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit"
                        class="w-full bg-surface-container-highest hover:bg-surface-bright text-white font-semibold py-4 px-6 rounded-lg flex items-center justify-center gap-3 transition-all border border-white/5">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Continue with Google
                </button>
            </form>
        </div>

        <!-- Footer -->
        <footer class="mt-10 text-center">
            <p class="text-slate-400 text-sm">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register"
                   class="text-primary font-bold hover:underline ml-1">Create Account</a>
            </p>
        </footer>
    </div>

    <!-- Legal Links -->
    <nav class="mt-12 flex justify-center gap-8 opacity-40 grayscale" aria-label="Legal">
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Privacy Policy</a>
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Terms of Service</a>
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Support</a>
    </nav>
</main>
