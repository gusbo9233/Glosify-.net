@model RegisterViewModel
@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Create Account";
}

<main class="auth-shell">
    <div class="brand-stack">
        <div class="brand-orb">
            <span class="material-symbols-outlined">graphic_eq</span>
        </div>
        <h1>Glosify</h1>
        <p class="brand-tagline">Sonic Language Immersion</p>
    </div>

    <section class="glass-card">
        <header class="auth-card-header">
            <h2>Create Account</h2>
            <p>Start your language immersion journey today.</p>
        </header>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div class="field">
                <label class="field-label" asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email"
                       class="field-input"
                       placeholder="name@@domain.com" autocomplete="email" />
            </div>

            <div class="field">
                <label class="field-label" asp-for="Password">Password</label>
                <input asp-for="Password" type="password"
                       class="field-input"
                       placeholder="••••••••" autocomplete="new-password" />
            </div>

            <div class="field">
                <label class="field-label" asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="field-input"
                       placeholder="••••••••" autocomplete="new-password" />
            </div>

            <button type="submit" class="btn-primary-pill">
                Create Account
                <span class="material-symbols-outlined">arrow_forward</span>
            </button>
        </form>

        <footer class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign In</a>
        </footer>
    </section>

    <nav class="legal-links" aria-label="Legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Support</a>
    </nav>
</main>
