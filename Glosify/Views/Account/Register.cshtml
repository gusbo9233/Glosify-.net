@model Glosify.Models.RegisterViewModel
@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Create Account";
}

<main class="w-full max-w-[480px] z-10">
    <!-- Brand Identity -->
    <div class="flex flex-col items-center mb-10">
        <div class="w-16 h-16 bg-primary-container rounded-lg flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(29,185,84,0.3)]">
            <span class="material-symbols-outlined text-on-primary-container text-4xl">graphic_eq</span>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tighter text-on-background mb-2">Glosify</h1>
        <p class="text-slate-400 font-medium tracking-tight">Sonic Language Immersion</p>
    </div>

    <!-- Register Card -->
    <div class="glass-effect rounded-xl p-8 md:p-12 border border-white/5 shadow-2xl">
        <header class="mb-10">
            <h2 class="text-2xl font-bold text-white mb-2">Create Account</h2>
            <p class="text-slate-400 text-sm">Start your language immersion journey today.</p>
        </header>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 rounded-md bg-error/10 border border-error/30 px-4 py-3 text-sm text-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- Email Field -->
            <div class="space-y-2">
                <label asp-for="Email" class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1">Email Address</label>
                <input asp-for="Email" type="email"
                       class="w-full bg-surface-container-lowest border-none rounded-md py-4 px-5 text-on-surface placeholder:text-slate-500 focus:ring-2 focus:ring-primary-container transition-all"
                       placeholder="name@domain.com" autocomplete="email" />
            </div>

            <!-- Password Field -->
            <div class="space-y-2">
                <label asp-for="Password" class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1">Password</label>
                <input asp-for="Password" type="password"
                       class="w-full bg-surface-container-lowest border-none rounded-md py-4 px-5 text-on-surface placeholder:text-slate-500 focus:ring-2 focus:ring-primary-container transition-all"
                       placeholder="••••••••" autocomplete="new-password" />
            </div>

            <!-- Confirm Password Field -->
            <div class="space-y-2">
                <label asp-for="ConfirmPassword" class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="w-full bg-surface-container-lowest border-none rounded-md py-4 px-5 text-on-surface placeholder:text-slate-500 focus:ring-2 focus:ring-primary-container transition-all"
                       placeholder="••••••••" autocomplete="new-password" />
            </div>

            <!-- Register Button -->
            <button type="submit"
                    class="w-full bg-primary-container text-on-primary font-bold py-4 rounded-full hover:scale-[1.02] active:scale-[0.98] transition-all shadow-[0_10px_30px_rgba(29,185,84,0.2)] flex items-center justify-center gap-2">
                Create Account
                <span class="material-symbols-outlined text-xl">arrow_forward</span>
            </button>
        </form>

        <!-- Footer -->
        <footer class="mt-10 text-center">
            <p class="text-slate-400 text-sm">
                Already have an account?
                <a asp-controller="Account" asp-action="Login"
                   class="text-primary font-bold hover:underline ml-1">Sign In</a>
            </p>
        </footer>
    </div>

    <!-- Legal Links -->
    <nav class="mt-12 flex justify-center gap-8 opacity-40 grayscale" aria-label="Legal">
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Privacy Policy</a>
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Terms of Service</a>
        <a href="#" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Support</a>
    </nav>
</main>
