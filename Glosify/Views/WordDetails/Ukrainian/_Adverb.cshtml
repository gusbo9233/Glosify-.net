@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">schedule</span>Adverb · Прислівник</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Function</span>
            <span class="fact-value">Adverbs modify verbs, adjectives, and other adverbs and are normally invariable.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Semantic Type</span>
            <span class="fact-value">@ValueOrFallback("type", "semantic_type", "Track manner (швидко, добре), time (вчора, потім), place (тут, додому), degree (дуже, надто), or cause (тому).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Origin</span>
            <span class="fact-value">@ValueOrFallback("origin", "derivation", "Most are derived from adjectives in -о / -е (швидкий → швидко, добрий → добре) or from frozen case forms (вранці, зимою).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Comparison</span>
            <span class="fact-value">@ValueOrFallback("comparison", "stupin_porivniannia", "Qualitative adverbs accept comparative -ше / -іше (швидше, краще) and superlative with най- (найшвидше).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Predicative</span>
            <span class="fact-value">@ValueOrFallback("predicative", "kategoriya_stanu", "Predicative adverbs (мені холодно, треба, можна) head impersonal sentences with a dative experiencer.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
