@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">campaign</span>Interjection · Вигук</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Expression</span>
            <span class="fact-value">Interjections express emotion, reaction, greeting, or imitation and stand outside normal sentence structure.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Tone</span>
            <span class="fact-value">@ValueOrFallback("tone", "emotion", "Track surprise (ой, ох), pain (ай), agreement (ага), hesitation (ну), greeting (привіт, добридень), or sound imitation (бах, тук-тук).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Register</span>
            <span class="fact-value">@ValueOrFallback("register", "style", "Mark colloquial, neutral, or formal — many interjections are markedly informal or expressive.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Inflection</span>
            <span class="fact-value">@ValueOrFallback("inflection", "declension", "Interjections do not inflect.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Punctuation</span>
            <span class="fact-value">@ValueOrFallback("punctuation", "comma", "Usually set off by a comma or exclamation mark (Ой, як гарно! / Гей! Сюди!).")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
