@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">title</span>Noun · Іменник</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Gender</span>
            <span class="fact-value">@ValueOrFallback("gender", "rid", "Masculine (чоловічий), feminine (жіночий), or neuter (середній); a few common-gender nouns exist (e.g. сирота).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Cases</span>
            <span class="fact-value">@ValueOrFallback("case", "declension", "Seven cases: nominative (називний), genitive (родовий), dative (давальний), accusative (знахідний), instrumental (орудний), locative (місцевий), vocative (кличний).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Declension Class</span>
            <span class="fact-value">@ValueOrFallback("declension_class", "vidmina", "Four declensions: I (-а/-я fem./masc.), II (zero/-о/-е), III (zero-ending fem.), IV (-я neuter with -ат-/-ен-).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Animacy</span>
            <span class="fact-value">@ValueOrFallback("animacy", "istota", "For masculine and plural nouns, the accusative copies the genitive when animate and the nominative when inanimate.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Number</span>
            <span class="fact-value">@ValueOrFallback("number", "chyslo", "Singular and plural; some nouns are pluralia tantum (двері, ножиці) or singularia tantum (молоко).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Vocative</span>
            <span class="fact-value">@ValueOrFallback("vocative", "klychnyi", "Direct address uses a distinct vocative form (друже, мамо, Олено) — restored as a full case in modern Ukrainian.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Stem Alternation</span>
            <span class="fact-value">@ValueOrFallback("alternation", "cherhuvannia", "Watch for о/і, е/і vowel alternations and consonant changes (г/з, к/ц, х/с) before certain endings.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
