@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">conversion_path</span>Preposition · Прийменник</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Governs Case</span>
            <span class="fact-value">@ValueOrFallback("governs_case", "case", "Each preposition selects one or more cases: genitive (без, для, від), dative (завдяки, всупереч), accusative (через, про), instrumental (з, над, перед), locative (в/у, на, при).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Direction vs Location</span>
            <span class="fact-value">@ValueOrFallback("direction", "napriamok", "В/у and на take the accusative for motion toward (іду в школу) and the locative for static location (живу в місті).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Variant Forms</span>
            <span class="fact-value">@ValueOrFallback("variants", "varianty", "Many prepositions alternate in shape: в / у / уві, з / із / зі / зо, від / од — choice depends on the surrounding sounds for euphony.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Relationship</span>
            <span class="fact-value">@ValueOrFallback("relationship", "meaning_type", "Track place, time, cause, purpose, manner, comparison, or quantity.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Triggers н- in Pronouns</span>
            <span class="fact-value">@ValueOrFallback("n_initial", "prefix_n", "After a preposition, third-person pronouns add н- (з ним, у неї, до них).")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
