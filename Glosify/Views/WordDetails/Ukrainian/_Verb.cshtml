@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">directions_run</span>Verb · Дієслово</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Aspect</span>
            <span class="fact-value">@ValueOrFallback("aspect", "vyd", "Every verb is either imperfective (недоконаний — process) or perfective (доконаний — completed event); most exist as aspectual pairs (писати / написати).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Conjugation</span>
            <span class="fact-value">@ValueOrFallback("conjugation", "diyevidmina", "First conjugation (-е-/-є- endings) or second conjugation (-и-/-ї- endings); a small set of athematic verbs (бути, дати, їсти).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Present / Future</span>
            <span class="fact-value">@ValueOrFallback("present", "future", "Imperfective verbs use синтетичний non-past for present (я роблю); perfective verbs use the same forms with future meaning (я зроблю). Imperfective future is analytic with буду + infinitive.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Past Tense</span>
            <span class="fact-value">@ValueOrFallback("past", "minuly_chas", "Past forms agree in gender and number with the subject: робив / робила / робило / робили — they do not show person.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Mood</span>
            <span class="fact-value">@ValueOrFallback("mood", "sposob", "Indicative, imperative (роби, робіть), and conditional with the particle би/б (робив би).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Reflexive (-ся)</span>
            <span class="fact-value">@ValueOrFallback("reflexive", "sia", "The postfix -ся / -сь forms reflexives, reciprocals, passives, and many lexicalised verbs (вчитися, зустрічатися).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Government</span>
            <span class="fact-value">@ValueOrFallback("rection", "case_government", "Verbs select case: transitive verbs take accusative; many take genitive (бракувати), dative (допомагати), instrumental (керувати), or specific prepositions.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Participles &amp; Verbal Adverbs</span>
            <span class="fact-value">@ValueOrFallback("participle", "diyepryslivnyk", "Past passive participle in -ний / -тий (зроблений, відкритий); active participles are limited; verbal adverb (дієприслівник) ends in -чи / -вши.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
