@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">conversion_path</span>Adposition / Kaassona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Government</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>form</th><td>@(Model.Word?.Lemma ?? "-")</td></tr>
                    <tr><th>position</th><td>@Property("position", "type", "mostly postposition; some prepositions")</td></tr>
                    <tr><th>governs case</th><td>@Property("governs_case", "case", "usually genitive for postpositions")</td></tr>
                    <tr><th>relationship</th><td>@Property("relationship", "meaning_type", "place, time, cause, comparison, or manner")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Local Series</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>to</th><td>@Property("to_form", "allative", "-")</td></tr>
                    <tr><th>at</th><td>@Property("at_form", "adessive", "-")</td></tr>
                    <tr><th>from</th><td>@Property("from_form", "ablative", "-")</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Property(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
