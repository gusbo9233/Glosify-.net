@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">palette</span>Adjective / Omadussona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Degree</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>positive</th><td>@FormOrWord("positive")</td></tr>
                    <tr><th>comparative</th><td>@Form("comparative")</td></tr>
                    <tr><th>superlative</th><td>@Form("superlative")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Core Cases</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>nominative</th><td>@Form("nominative", "singular")</td></tr>
                    <tr><th>genitive</th><td>@Form("genitive")</td></tr>
                    <tr><th>partitive</th><td>@Form("partitive")</td></tr>
                    <tr><th>plural nominative</th><td>@Form("nominative", "plural")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Agreement Notes</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>noun agreement</th><td>case and number</td></tr>
                    <tr><th>fixed cases</th><td>terminative, essive, abessive, comitative often keep the genitive adjective form</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string FormOrWord(params string[] tags)
    {
        var form = Form(tags);
        return form == "-" ? Model.Word?.Lemma ?? "-" : form;
    }

    private string Form(params string[] tags)
    {
        return Model.Variants
            .Where(variant => !string.IsNullOrWhiteSpace(variant.Form) && variant.Form != "-")
            .Where(variant => tags.All(tag => variant.HasAnyTag(tag)))
            .OrderBy(variant => variant.Tags.Count)
            .Select(variant => variant.Form)
            .FirstOrDefault() ?? "-";
    }
}
