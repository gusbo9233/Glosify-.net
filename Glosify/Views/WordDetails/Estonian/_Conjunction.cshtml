@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">lan</span>Conjunction / Sidesona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Clause Role</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>form</th><td>@(Model.Word?.Lemma ?? "-")</td></tr>
                    <tr><th>type</th><td>@Property("type", "clause_type", "coordinating or subordinating")</td></tr>
                    <tr><th>connects</th><td>@Property("connects", "scope", "words, phrases, clauses, or sentences")</td></tr>
                    <tr><th>punctuation</th><td>@Property("punctuation", "comma", "subordinate clauses usually take a comma")</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Property(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
