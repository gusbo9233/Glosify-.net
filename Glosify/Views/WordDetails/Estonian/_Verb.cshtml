@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">directions_run</span>Verb / Tegusona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Principal Forms</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>ma-infinitive</th><td>@Form("infinitive ma", "nominative", "active")</td></tr>
                    <tr><th>da-infinitive</th><td>@Form("infinitive da")</td></tr>
                    <tr><th>Present participle</th><td>@Form("participle", "present", "active")</td></tr>
                    <tr><th>Past participle</th><td>@Form("participle", "past", "active")</td></tr>
                    <tr><th>Impersonal participle</th><td>@Form("participle", "past", "passive")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Indicative Present</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>mina</th><td>@Form("indicative", "present", "first person", "singular")</td></tr>
                    <tr><th>sina</th><td>@Form("indicative", "present", "second person", "singular")</td></tr>
                    <tr><th>tema</th><td>@Form("indicative", "present", "third person", "singular")</td></tr>
                    <tr><th>meie</th><td>@Form("indicative", "present", "first person", "plural")</td></tr>
                    <tr><th>teie</th><td>@Form("indicative", "present", "second person", "plural")</td></tr>
                    <tr><th>nemad</th><td>@Form("indicative", "present", "third person", "plural")</td></tr>
                    <tr><th>negative</th><td>@Form("indicative", "present", "negative")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Indicative Past</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>mina</th><td>@Form("indicative", "past", "first person", "singular")</td></tr>
                    <tr><th>sina</th><td>@Form("indicative", "past", "second person", "singular")</td></tr>
                    <tr><th>tema</th><td>@Form("indicative", "past", "third person", "singular")</td></tr>
                    <tr><th>meie</th><td>@Form("indicative", "past", "first person", "plural")</td></tr>
                    <tr><th>teie</th><td>@Form("indicative", "past", "second person", "plural")</td></tr>
                    <tr><th>nemad</th><td>@Form("indicative", "past", "third person", "plural")</td></tr>
                    <tr><th>negative</th><td>@Form("indicative", "past", "negative")</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Other Common Forms</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>conditional</th><td>@Form("conditional", "present", "third person", "singular")</td></tr>
                    <tr><th>imperative 2sg</th><td>@Form("imperative", "present", "second person", "singular")</td></tr>
                    <tr><th>imperative 2pl</th><td>@Form("imperative", "present", "second person", "plural")</td></tr>
                    <tr><th>quotative</th><td>@Form("quotative", "present", "active")</td></tr>
                    <tr><th>impersonal present</th><td>@Form("impersonal", "indicative", "present")</td></tr>
                    <tr><th>impersonal past</th><td>@Form("impersonal", "indicative", "past")</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Form(params string[] tags)
    {
        return Model.Variants
            .Where(variant => !string.IsNullOrWhiteSpace(variant.Form) && variant.Form != "-")
            .Where(variant => tags.All(tag => variant.HasAnyTag(tag)))
            .OrderBy(variant => variant.Tags.Count)
            .Select(variant => variant.Form)
            .FirstOrDefault() ?? "-";
    }
}
