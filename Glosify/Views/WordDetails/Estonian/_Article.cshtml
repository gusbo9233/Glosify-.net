@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">view_column</span>Article / Artikkel</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Estonian Article System</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>definite article</th><td>none</td></tr>
                    <tr><th>indefinite article</th><td>none</td></tr>
                    <tr><th>definiteness cues</th><td>@Property("definiteness", "cues", "context, word order, demonstratives, and object case")</td></tr>
                    <tr><th>article-like words</th><td>see, too, uks when emphasis requires it</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Property(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
