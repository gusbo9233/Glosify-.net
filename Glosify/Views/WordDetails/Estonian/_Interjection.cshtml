@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">campaign</span>Interjection · Hüüdsõna</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Expression</span>
            <span class="fact-value">Interjections express emotion, reaction, greeting, or emphasis and stand outside normal sentence structure.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Tone</span>
            <span class="fact-value">@ValueOrFallback("tone", "emotion", "Track surprise (oi, oo), pain (ai, ah), agreement (jaa), hesitation (noh), or greeting (tere, tšau).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Register</span>
            <span class="fact-value">@ValueOrFallback("register", "style", "Mark colloquial, neutral, or formal — many interjections are markedly informal.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Inflection</span>
            <span class="fact-value">@ValueOrFallback("inflection", "declension", "Interjections do not inflect.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
