@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">campaign</span>Interjection / Huudsona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Expression</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>form</th><td>@(Model.Word?.Lemma ?? "-")</td></tr>
                    <tr><th>tone</th><td>@Property("tone", "emotion", "emotion, reaction, greeting, hesitation, or emphasis")</td></tr>
                    <tr><th>register</th><td>@Property("register", "style", "neutral, colloquial, formal, or slang")</td></tr>
                    <tr><th>inflection</th><td>does not inflect</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Property(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
