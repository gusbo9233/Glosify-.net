@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">schedule</span>Adverb · Määrsõna</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Function</span>
            <span class="fact-value">Adverbs modify verbs, adjectives, or other adverbs and are usually invariable.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Semantic Type</span>
            <span class="fact-value">@ValueOrFallback("type", "semantic_type", "Track time (siis, eile), place (siin, kodus), manner (kiiresti), or degree (väga).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Origin</span>
            <span class="fact-value">@ValueOrFallback("origin", "derivation", "Many adverbs are frozen case forms of nouns or adjectives (e.g. kodus = inessive of kodu).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Comparison</span>
            <span class="fact-value">@ValueOrFallback("comparison", "degree", "Some adverbs accept comparative -mini and superlative kõige … -mini.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Position</span>
            <span class="fact-value">@ValueOrFallback("position", "word_order", "Word order is flexible; topic and focus shift adverb placement.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
