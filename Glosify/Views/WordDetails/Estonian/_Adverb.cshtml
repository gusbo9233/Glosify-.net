@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">schedule</span>Adverb / Maarsona</h2>
    <div class="slot-grid">
        <div class="slot-group">
            <h3 class="slot-heading">Function</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>base form</th><td>@(Model.Word?.Lemma ?? "-")</td></tr>
                    <tr><th>semantic type</th><td>@Property("type", "semantic_type", "time, place, manner, degree, or discourse")</td></tr>
                    <tr><th>inflection</th><td>usually invariable</td></tr>
                </tbody>
            </table>
        </div>

        <div class="slot-group">
            <h3 class="slot-heading">Comparison</h3>
            <table class="slot-table">
                <tbody>
                    <tr><th>comparative</th><td>@Form("comparative")</td></tr>
                    <tr><th>superlative</th><td>@Form("superlative")</td></tr>
                    <tr><th>derived from</th><td>@Property("origin", "derivation", "often a frozen case form")</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</article>

@functions {
    private string Property(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }

    private string Form(params string[] tags)
    {
        return Model.Variants
            .Where(variant => !string.IsNullOrWhiteSpace(variant.Form) && variant.Form != "-")
            .Where(variant => tags.All(tag => variant.HasAnyTag(tag)))
            .OrderBy(variant => variant.Tags.Count)
            .Select(variant => variant.Form)
            .FirstOrDefault() ?? "-";
    }
}
