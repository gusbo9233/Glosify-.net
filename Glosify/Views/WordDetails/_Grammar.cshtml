@model WordDetailViewModel
@{
    var config = Model.WordClassConfig;
    if (config == null)
    {
        return;
    }

    var variantRows = BuildVariantRows();
}

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">@config.Icon</span>@config.Title</h2>

    @if (config.Facts.Length > 0)
    {
        var facts = config.Facts
            .Select(f => new { f.Label, Value = LookupValue(f.PropertyKeys) })
            .Where(f => !string.IsNullOrWhiteSpace(f.Value))
            .ToList();

        if (facts.Any())
        {
            <div class="fact-grid">
                @foreach (var fact in facts)
                {
                    <div class="fact-item">
                        <span class="fact-key">@fact.Label</span>
                        <span class="fact-value">@fact.Value</span>
                    </div>
                }
            </div>
        }
    }

    @if (variantRows.Any())
    {
        <div class="slot-grid">
            @foreach (var group in variantRows.GroupBy(row => row.Group))
            {
                <div class="slot-group">
                    <h3 class="slot-heading">@group.Key</h3>
                    <table class="slot-table">
                        <tbody>
                            @foreach (var row in group)
                            {
                                <tr>
                                    <th>@row.Label</th>
                                    <td>@row.Forms</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</article>

@functions {
    private string? LookupValue(string[] keys)
    {
        foreach (var key in keys)
        {
            var val = Model.GetProperty(key);
            if (!string.IsNullOrWhiteSpace(val)) return val;
        }
        return null;
    }

    private IReadOnlyList<VariantDisplayRow> BuildVariantRows()
    {
        return Model.Variants
            .Where(variant => !string.IsNullOrWhiteSpace(variant.Form) && variant.Form != "-")
            .GroupBy(variant => new
            {
                Group = DisplayGroup(variant),
                Label = DisplayLabel(variant)
            })
            .Select(group => new VariantDisplayRow(
                group.Key.Group,
                group.Key.Label,
                string.Join(", ", group
                    .Select(variant => variant.Form)
                    .Where(form => !string.IsNullOrWhiteSpace(form))
                    .Distinct())))
            .Where(row => !string.IsNullOrWhiteSpace(row.Label) && !string.IsNullOrWhiteSpace(row.Forms))
            .OrderBy(row => row.Group, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string DisplayGroup(WordDetailVariantViewModel variant)
    {
        return string.IsNullOrWhiteSpace(variant.Group)
            ? "Forms"
            : Humanize(variant.Group);
    }

    private static string DisplayLabel(WordDetailVariantViewModel variant)
    {
        if (!string.IsNullOrWhiteSpace(variant.Label))
        {
            return Humanize(variant.Label);
        }

        return variant.Tags.Count == 0
            ? "Form"
            : string.Join(" ", variant.Tags.Select(Humanize));
    }

    private static string Humanize(string value) => WordDetailJsonReader.Humanize(value);

    private sealed record VariantDisplayRow(string Group, string Label, string Forms);
}
