@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">title</span>Noun · Rzeczownik</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Gender</span>
            <span class="fact-value">@ValueOrFallback("gender", "rodzaj", "Singular: masculine personal (m-os.), masculine animate (m-żyw.), masculine inanimate (m-rz.), feminine, neuter. Plural collapses to masculine personal vs non-masculine personal (rodzaj męskoosobowy / niemęskoosobowy).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Cases</span>
            <span class="fact-value">@ValueOrFallback("case", "deklinacja", "Seven cases: mianownik, dopełniacz, celownik, biernik, narzędnik, miejscownik, wołacz.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Animacy / Virility</span>
            <span class="fact-value">@ValueOrFallback("animacy", "męskoosobowość", "Masculine singular accusative copies the genitive when animate, the nominative when inanimate. In the plural, masculine personal nouns trigger męskoosobowy agreement (ci dobrzy panowie) vs non-personal niemęskoosobowy (te dobre psy).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Declension Pattern</span>
            <span class="fact-value">@ValueOrFallback("declension_class", "wzór", "Endings depend on stem hardness (hard, soft, palatalised) and gender; many masculine nouns take genitive sg in -a (chłopa) or -u (stołu) — choice is partly lexical.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Vocative</span>
            <span class="fact-value">@ValueOrFallback("vocative", "wołacz", "Used in direct address (Panie Profesorze!, Aniu!); often replaced by the nominative in informal speech but standard in writing.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Stem Alternations</span>
            <span class="fact-value">@ValueOrFallback("alternation", "oboczności", "Watch for o↔ó (stół ↔ stołu), e↔ø fleeting vowel (pies ↔ psa), and consonant softening before -e (Kraków ↔ w Krakowie, ręka ↔ ręce).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Number</span>
            <span class="fact-value">@ValueOrFallback("number", "liczba", "Singular and plural; some nouns are pluralia tantum (drzwi, spodnie, urodziny) or singularia tantum.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
