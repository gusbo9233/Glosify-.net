@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">person</span>Pronoun · Zaimek</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Type</span>
            <span class="fact-value">@ValueOrFallback("type", "subtype", "Personal (ja, ty, on, ona, ono, my, wy, oni, one), reflexive (się / siebie), possessive (mój, twój, nasz, wasz, swój), demonstrative (ten, ta, to, tamten), interrogative / relative (kto, co, jaki, który, czyj), negative (nikt, nic), or indefinite (ktoś, coś).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Person &amp; Number</span>
            <span class="fact-value">@ValueOrFallback("person", "osoba", "Three persons, two numbers; pan / pani / państwo are used for polite address with third-person verb agreement.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Case Forms</span>
            <span class="fact-value">@ValueOrFallback("case", "deklinacja", "Pronouns inflect in all seven cases; personal pronoun paradigms are largely suppletive (ja → mnie → mi).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Short vs Long Forms</span>
            <span class="fact-value">@ValueOrFallback("clitic", "formy_krotkie", "Personal pronouns have unstressed clitics (mi, ci, mu, go) and stressed full forms (mnie, tobie, jemu, jego); the long form goes after a preposition or in emphatic position.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Initial n-</span>
            <span class="fact-value">@ValueOrFallback("n_initial", "prefiks_n", "Third-person pronouns add n- after a preposition (do niego, z nią, przy nich).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Plural Virility</span>
            <span class="fact-value">@ValueOrFallback("virility", "rodzaj", "Plural oni refers to a group containing at least one masculine personal noun; one is used for everyone else (women-only, animals, things).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Reflexive się / siebie</span>
            <span class="fact-value">@ValueOrFallback("reflexive", "siebie", "Się / siebie has no nominative and refers back to the clause subject regardless of person; the clitic się is mobile and may follow the verb or another constituent.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
