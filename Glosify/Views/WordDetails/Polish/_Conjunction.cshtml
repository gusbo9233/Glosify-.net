@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">lan</span>Conjunction · Spójnik</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Clause Role</span>
            <span class="fact-value">@ValueOrFallback("type", "clause_type", "Coordinating (i, oraz, a, ale, lecz, jednak, albo, lub, czy) or subordinating (że, żeby, aby, bo, ponieważ, gdy, kiedy, jeśli, choć, chociaż).")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Word Order</span>
            <span class="fact-value">@ValueOrFallback("word_order", "szyk", "Word order is fairly free and information-driven; conjunctions do not force the verb to a fixed position as in German.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Connects</span>
            <span class="fact-value">@ValueOrFallback("connects", "scope", "Connects words, phrases, clauses, or full sentences.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Punctuation</span>
            <span class="fact-value">@ValueOrFallback("punctuation", "interpunkcja", "Subordinate clauses are always set off by a comma in Polish (much stricter than English): Wiem, że masz rację. Coordinating i, lub, ani usually take no comma when joining only two items.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">a vs i vs ale</span>
            <span class="fact-value">@ValueOrFallback("a_i_ale", "kontrast", "I links similar items, a contrasts gently or shifts topic (Ja idę, a ty zostajesz), ale marks a stronger contradiction. They are not interchangeable.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
