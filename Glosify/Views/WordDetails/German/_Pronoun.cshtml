@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">person</span>Pronoun · Pronomen / Fürwort</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Person</span>
            <span class="fact-value">@ValueOrFallback("person", "type", "Track personal, possessive, demonstrative, relative, or indefinite use.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Number</span>
            <span class="fact-value">@ValueOrFallback("number", "numerus", "Mark singular or plural.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Case Forms</span>
            <span class="fact-value">@ValueOrFallback("case", "declension", "Use variants for ich, mich, mir style case forms.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Gender</span>
            <span class="fact-value">@ValueOrFallback("gender", "genus", "Relevant for third-person, possessive, and demonstrative pronouns.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
