@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">schedule</span>Adverb · Adverb / Umstandswort</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Function</span>
            <span class="fact-value">Adverbs modify verbs, adjectives, clauses, or other adverbs.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Semantic Type</span>
            <span class="fact-value">@ValueOrFallback("type", "semantic_type", "Track time, place, manner, degree, or frequency.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Inflection</span>
            <span class="fact-value">@ValueOrFallback("inflection", "declension", "Most German adverbs are invariable.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Position</span>
            <span class="fact-value">@ValueOrFallback("position", "word_order", "Add sentence-position notes when useful.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
