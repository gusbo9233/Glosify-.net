@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">title</span>Noun · Nomen / Hauptwort</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Capitalization</span>
            <span class="fact-value">German nouns are always capitalized.</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Article / Gender</span>
            <span class="fact-value">@ValueOrFallback("article", "gender", "Add der, die, or das when known.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Plural</span>
            <span class="fact-value">@ValueOrFallback("plural", "number", "Add the plural form when known.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Case Behavior</span>
            <span class="fact-value">@ValueOrFallback("case", "declension", "Track nominative, accusative, dative, and genitive forms when useful.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
