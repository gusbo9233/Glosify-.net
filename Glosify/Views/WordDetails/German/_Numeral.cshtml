@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">pin</span>Numeral · Numerale / Zahlwort</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Kind</span>
            <span class="fact-value">@ValueOrFallback("type", "kind", "Track cardinal, ordinal, fraction, or multiplicative.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Value</span>
            <span class="fact-value">@ValueOrFallback("value", "quantity", "Add the numeric value when useful.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Inflection</span>
            <span class="fact-value">@ValueOrFallback("inflection", "declension", "Ordinal numbers usually decline like adjectives.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Usage</span>
            <span class="fact-value">@ValueOrFallback("usage", "context", "Track quantity, order, dates, or fixed expressions.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
