@model Glosify.Models.WordDetailViewModel

<article class="detail-section wide">
    <h2 class="section-title"><span class="material-symbols-outlined">lan</span>Conjunction · Konjunktion / Bindewort</h2>
    <div class="fact-grid">
        <div class="fact-item">
            <span class="fact-key">Clause Role</span>
            <span class="fact-value">@ValueOrFallback("type", "clause_type", "Mark coordinating, subordinating, or correlative.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Word Order</span>
            <span class="fact-value">@ValueOrFallback("word_order", "verb_position", "Subordinating conjunctions usually send the finite verb to the end.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Connects</span>
            <span class="fact-value">@ValueOrFallback("connects", "scope", "Connects words, phrases, clauses, or full sentences.")</span>
        </div>
        <div class="fact-item">
            <span class="fact-key">Punctuation</span>
            <span class="fact-value">@ValueOrFallback("punctuation", "comma", "Subordinate clauses are normally separated by commas.")</span>
        </div>
    </div>
</article>

@functions {
    private string ValueOrFallback(string firstKey, string secondKey, string fallback)
    {
        var first = Model.GetProperty(firstKey);
        return string.IsNullOrWhiteSpace(first) ? (Model.GetProperty(secondKey) is var second && !string.IsNullOrWhiteSpace(second) ? second : fallback) : first;
    }
}
