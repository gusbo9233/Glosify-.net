@model WordDetailViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    var displayWord = Model.Word?.Lemma ?? "Word details";
    ViewData["Title"] = displayWord;
    ViewData["ActiveNav"] = "quizzes";

    var isEnriched = Model.Properties.Any()
        && Model.Variants.Any()
        && !string.IsNullOrWhiteSpace(Model.Detail.Explanation)
        && !string.IsNullOrWhiteSpace(Model.Detail.ExampleSentence);
}



<section class="detail-page">
    <div class="detail-topbar">
        <a class="back-link" asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Quiz.Id">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to quiz
        </a>
        <div class="detail-actions">
            <form method="post" asp-action="Regenerate" asp-route-id="@Model.Detail.Id">
                @Html.AntiForgeryToken()
                @if (isEnriched)
                {
                    <button class="edit-link regenerate-button" type="submit">
                        <span class="material-symbols-outlined">sync</span>
                        Regenerate
                    </button>
                }
                else
                {
                    <button class="edit-link generate-button" type="submit">
                        <span class="material-symbols-outlined">auto_awesome</span>
                        Generate details
                    </button>
                }
            </form>
            <a class="edit-link" asp-action="Edit" asp-route-id="@Model.Detail.Id">
                <span class="material-symbols-outlined">edit</span>
                Edit
            </a>
        </div>
    </div>

    @if (TempData["WordDetailMessage"] is string message)
    {
        <p class="detail-message">@message</p>
    }

    <section class="detail-hero">
        <div class="hero-panel">
            <p class="detail-label">@Model.Quiz.SourceLanguage &rarr; @Model.Quiz.TargetLanguage</p>
            <h1 class="detail-title">@displayWord</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Word?.Translation))
            {
                <p class="detail-translation">@Model.Word.Translation</p>
            }
        </div>

        <aside class="meta-panel">
            <div class="meta-item">
                <span class="meta-key">Quiz</span>
                <span class="meta-value">@Model.Quiz.Name</span>
            </div>
            <div class="meta-item">
                <span class="meta-key">Language</span>
                <span class="meta-value">@(string.IsNullOrWhiteSpace(Model.Detail.Language) ? Model.Quiz.TargetLanguage : Model.Detail.Language)</span>
            </div>
            <div class="meta-item">
                <span class="meta-key">Status</span>
                <span class="meta-value">@Model.Quiz.ProcessingStatus</span>
            </div>
        </aside>
    </section>

    <section class="detail-grid">
        <article class="detail-section wide">
            <div class="property-toolbar">
                <h2 class="section-title"><span class="material-symbols-outlined">category</span>Properties</h2>
            </div>
            @if (!Model.Properties.Any())
            {
                <p class="section-copy empty-copy">No grammatical properties have been added yet.</p>
            }
            else
            {
                <div class="fact-grid">
                    @foreach (var property in Model.Properties)
                    {
                        <div class="fact-item">
                            <span class="fact-key">@Humanize(property.Key)</span>
                            <span class="fact-value">@Humanize(property.Value)</span>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="detail-section wide">
            <h2 class="section-title"><span class="material-symbols-outlined">notes</span>Explanation</h2>
            @if (string.IsNullOrWhiteSpace(Model.Explanation))
            {
                <p class="section-copy empty-copy">No explanation has been added yet.</p>
            }
            else
            {
                <p class="section-copy">@Model.Explanation</p>
            }
        </article>

        <article class="detail-section">
            <h2 class="section-title"><span class="material-symbols-outlined">format_quote</span>Example</h2>
            @if (string.IsNullOrWhiteSpace(Model.ExampleSentence))
            {
                <p class="section-copy empty-copy">No example sentence has been added yet.</p>
            }
            else
            {
                <p class="section-copy">@Model.ExampleSentence</p>
                @if (!string.IsNullOrWhiteSpace(Model.ExampleSentenceTranslation))
                {
                    <p class="section-copy example-translation">@Model.ExampleSentenceTranslation</p>
                }
            }
        </article>

        <article class="detail-section">
            <h2 class="section-title"><span class="material-symbols-outlined">schema</span>Variants</h2>
            @if (!Model.Variants.Any())
            {
                <p class="section-copy empty-copy">No variants have been added yet.</p>
            }
            else
            {
                <div class="variant-list">
                    @foreach (var variant in Model.Variants)
                    {
                        <div class="variant-row">
                            <span class="variant-form">@variant.Form</span>
                            <span class="tag-list">
                                @if (!string.IsNullOrWhiteSpace(variant.Label))
                                {
                                    <span class="tag">@Humanize(variant.Label)</span>
                                }
                                else
                                {
                                    @foreach (var tag in variant.Tags)
                                    {
                                        <span class="tag">@Humanize(tag)</span>
                                    }
                                }
                            </span>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
</section>

@await Html.PartialAsync("~/Views/Quiz/_AssistantPanel.cshtml", new AssistantPanelViewModel
{
    QuizId = Model.Quiz.Id,
    FocusedWordId = Model.Word?.Id,
    ContextLabel = displayWord,
    EmptyText = "Ask about this word or request changes.",
    Placeholder = $"Ask about {displayWord}..."
})

@section Scripts {
<script src="~/js/assistant.js"></script>
}

@functions {
    private static string Humanize(string value) => WordDetailJsonReader.Humanize(value);
}
