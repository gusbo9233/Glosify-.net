@model Glosify.Models.WordDetailViewModel
@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    var displayWord = Model.Word?.Lemma ?? "Word details";
    var grammarPartial = GrammarPartialName(Model);
    ViewData["Title"] = displayWord;
    ViewData["ActiveNav"] = "quizzes";
}



<section class="detail-page">
    <div class="detail-topbar">
        <a class="back-link" asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Quiz.Id">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to quiz
        </a>
        <a class="edit-link" asp-action="Edit" asp-route-id="@Model.Detail.Id">
            <span class="material-symbols-outlined">edit</span>
            Edit
        </a>
    </div>

    <section class="detail-hero">
        <div class="hero-panel">
            <p class="detail-label">@Model.Quiz.SourceLanguage &rarr; @Model.Quiz.TargetLanguage</p>
            <h1 class="detail-title">@displayWord</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Word?.Translation))
            {
                <p class="detail-translation">@Model.Word.Translation</p>
            }
        </div>

        <aside class="meta-panel">
            <div class="meta-item">
                <span class="meta-key">Quiz</span>
                <span class="meta-value">@Model.Quiz.Name</span>
            </div>
            <div class="meta-item">
                <span class="meta-key">Language</span>
                <span class="meta-value">@(string.IsNullOrWhiteSpace(Model.Detail.Language) ? Model.Quiz.TargetLanguage : Model.Detail.Language)</span>
            </div>
            <div class="meta-item">
                <span class="meta-key">Status</span>
                <span class="meta-value">@Model.Quiz.ProcessingStatus</span>
            </div>
            @if (Model.HasDictionaryMatch)
            {
                <div class="meta-item">
                    <span class="meta-key">Dictionary</span>
                    <span class="meta-value">@Model.DictionaryMatch!.Source · @Model.DictionaryMatch.Word</span>
                </div>
            }
        </aside>
    </section>

    <section class="detail-grid">
        <article class="detail-section wide">
            <div class="property-toolbar">
                <h2 class="section-title"><span class="material-symbols-outlined">category</span>Properties</h2>
                <form class="property-form" method="post" asp-action="UpdatePartOfSpeech" asp-route-id="@Model.Detail.Id">
                    @Html.AntiForgeryToken()
                    <label class="fact-key" for="partOfSpeech">Word Class</label>
                    <select class="property-select" id="partOfSpeech" name="partOfSpeech" onchange="this.form.submit()">
                        <option value="" selected="@string.IsNullOrWhiteSpace(Model.PartOfSpeech)">Unclassified</option>
                        <option value="noun" selected="@IsSelected("noun")">Noun / Nomen</option>
                        <option value="verb" selected="@IsSelected("verb")">Verb / Verb</option>
                        <option value="article" selected="@IsSelected("article")">Article / Artikel</option>
                        <option value="adjective" selected="@IsSelected("adjective")">Adjective / Adjektiv</option>
                        <option value="pronoun" selected="@IsSelected("pronoun")">Pronoun / Pronomen</option>
                        <option value="adverb" selected="@IsSelected("adverb")">Adverb / Adverb</option>
                        <option value="preposition" selected="@IsSelected("preposition")">Preposition / Präposition</option>
                        <option value="conjunction" selected="@IsSelected("conjunction")">Conjunction / Konjunktion</option>
                        <option value="numeral" selected="@IsSelected("numeral")">Numeral / Numerale</option>
                        <option value="interjection" selected="@IsSelected("interjection")">Interjection / Interjektion</option>
                    </select>
                </form>
            </div>
            @if (!Model.Properties.Any())
            {
                <p class="section-copy empty-copy">No grammatical properties have been added yet.</p>
            }
            else
            {
                <div class="fact-grid">
                    @foreach (var property in Model.Properties)
                    {
                        <div class="fact-item">
                            <span class="fact-key">@Humanize(property.Key)</span>
                            <span class="fact-value">@Humanize(property.Value)</span>
                        </div>
                    }
                </div>
            }
        </article>

        @if (!string.IsNullOrWhiteSpace(grammarPartial))
        {
            <partial name="@grammarPartial" model="Model" />
        }

        <article class="detail-section wide">
            <h2 class="section-title"><span class="material-symbols-outlined">notes</span>Explanation</h2>
            @if (string.IsNullOrWhiteSpace(Model.Explanation))
            {
                <p class="section-copy empty-copy">No explanation has been added yet.</p>
            }
            else
            {
                <p class="section-copy">@Model.Explanation</p>
            }
        </article>

        <article class="detail-section">
            <h2 class="section-title"><span class="material-symbols-outlined">format_quote</span>Example</h2>
            @if (string.IsNullOrWhiteSpace(Model.ExampleSentence))
            {
                <p class="section-copy empty-copy">No example sentence has been added yet.</p>
            }
            else
            {
                <p class="section-copy">@Model.ExampleSentence</p>
            }
        </article>

        @if (ShouldShowGenericVariants(Model))
        {
            <article class="detail-section">
                <h2 class="section-title"><span class="material-symbols-outlined">schema</span>Variants</h2>
                @if (!Model.Variants.Any())
                {
                    <p class="section-copy empty-copy">No variants have been added yet.</p>
                }
                else
                {
                    <div class="variant-list">
                        @foreach (var variant in Model.Variants)
                        {
                            <div class="variant-row">
                                <span class="variant-form">@variant.Form</span>
                                <span class="tag-list">
                                    @foreach (var tag in variant.Tags)
                                    {
                                        <span class="tag">@Humanize(tag)</span>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                }
            </article>
        }
    </section>
</section>

@functions {
    private static string GrammarPartialName(Glosify.Models.WordDetailViewModel model)
    {
        var language = string.IsNullOrWhiteSpace(model.Detail.Language) ? model.Quiz.TargetLanguage : model.Detail.Language;
        var folder = ResolveLanguageFolder(language);
        if (string.IsNullOrEmpty(folder))
        {
            return string.Empty;
        }

        var partOfSpeech = NormalizePartOfSpeech(model.PartOfSpeech);
        if (string.IsNullOrEmpty(partOfSpeech))
        {
            return string.Empty;
        }

        return $"{folder}/_{partOfSpeech}";
    }

    private static string ResolveLanguageFolder(string language)
    {
        if (string.IsNullOrWhiteSpace(language))
        {
            return string.Empty;
        }

        if (language.Equals("de", StringComparison.OrdinalIgnoreCase)
            || language.Contains("german", StringComparison.OrdinalIgnoreCase)
            || language.Contains("deutsch", StringComparison.OrdinalIgnoreCase))
        {
            return "German";
        }

        if (language.Equals("et", StringComparison.OrdinalIgnoreCase)
            || language.Contains("estonian", StringComparison.OrdinalIgnoreCase)
            || language.Contains("eesti", StringComparison.OrdinalIgnoreCase))
        {
            return "Estonian";
        }

        if (language.Equals("uk", StringComparison.OrdinalIgnoreCase)
            || language.Contains("ukrainian", StringComparison.OrdinalIgnoreCase)
            || language.Contains("ukrainisch", StringComparison.OrdinalIgnoreCase)
            || language.Contains("українськ", StringComparison.OrdinalIgnoreCase))
        {
            return "Ukrainian";
        }

        if (language.Equals("pl", StringComparison.OrdinalIgnoreCase)
            || language.Contains("polish", StringComparison.OrdinalIgnoreCase)
            || language.Contains("polski", StringComparison.OrdinalIgnoreCase)
            || language.Contains("polnisch", StringComparison.OrdinalIgnoreCase))
        {
            return "Polish";
        }

        return string.Empty;
    }

    private static string NormalizePartOfSpeech(string partOfSpeech)
    {
        return partOfSpeech.ToLowerInvariant() switch
        {
            "noun" or "nomen" or "hauptwort" or "substantiv" or "nimisõna" or "nimisona" or "іменник" or "rzeczownik" => "Noun",
            "verb" or "verben" or "zeitwort" or "tegusõna" or "tegusona" or "дієслово" or "czasownik" => "Verb",
            "article" or "artikel" or "geschlechtswort" or "artikkel" or "артикль" or "przedimek" or "rodzajnik" => "Article",
            "adjective" or "adjektiv" or "eigenschaftswort" or "omadussõna" or "omadussona" or "прикметник" or "przymiotnik" => "Adjective",
            "pronoun" or "pronomen" or "fuerwort" or "fürwort" or "asesõna" or "asesona" or "займенник" or "zaimek" => "Pronoun",
            "adverb" or "adverbien" or "umstandswort" or "määrsõna" or "maarsona" or "прислівник" or "przysłówek" or "przyslowek" => "Adverb",
            "preposition" or "präposition" or "praeposition" or "verhältniswort" or "verhaeltniswort"
                or "postposition" or "adposition" or "kaassõna" or "kaassona" or "прийменник" or "przyimek" => "Preposition",
            "conjunction" or "konjunktion" or "bindewort" or "sidesõna" or "sidesona" or "сполучник" or "spójnik" or "spojnik" => "Conjunction",
            "numeral" or "numerale" or "zahlwort" or "arvsõna" or "arvsona" or "числівник" or "liczebnik" => "Numeral",
            "interjection" or "interjektion" or "einwurf" or "hüüdsõna" or "huudsona" or "вигук" or "wykrzyknik" => "Interjection",
            _ => string.Empty
        };
    }

    private static string Humanize(string value) => Glosify.Models.WordDetailViewModel.Humanize(value);

    private static bool ShouldShowGenericVariants(Glosify.Models.WordDetailViewModel model)
    {
        var language = string.IsNullOrWhiteSpace(model.Detail.Language) ? model.Quiz.TargetLanguage : model.Detail.Language;
        var folder = ResolveLanguageFolder(language);
        var partOfSpeech = NormalizePartOfSpeech(model.PartOfSpeech);
        return folder != "Estonian";
    }

    private bool IsSelected(string partOfSpeech)
    {
        return string.Equals(Model.PartOfSpeech, partOfSpeech, StringComparison.OrdinalIgnoreCase);
    }
}
