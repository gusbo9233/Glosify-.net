    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #041329;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-player {
            background: rgba(17, 32, 54, 0.9);
            backdrop-filter: blur(40px);
        }
    </style>
</head>
<body class="text-on-surface selection:bg-primary selection:text-on-primary overflow-hidden">
    <!-- SideNavBar -->
    <aside class="h-full w-64 fixed left-0 top-0 hidden md:flex flex-col bg-[#041329] dark:bg-[#041329] font-['Plus_Jakarta_Sans'] text-sm tracking-tight z-50">
        <div class="flex flex-col gap-y-6 py-8 px-6 h-full">
            <div class="mb-8">
                <span class="text-2xl font-bold tracking-tighter text-[#1DB954]">Sonic Polyglot</span>
                <p class="text-slate-400 text-xs mt-1">Premium Learner</p>
            </div>
            <nav class="flex flex-col gap-y-4">
                <a class="text-[#1DB954] font-bold border-l-4 border-[#1DB954] pl-4 flex items-center gap-x-4 transition-colors duration-300" href="#">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home</span>
                    Home
                </a>
                <a class="text-slate-400 font-medium pl-4 hover:text-white flex items-center gap-x-4 transition-colors duration-300" href="#">
                    <span class="material-symbols-outlined">search</span>
                    Search
                </a>
                <a class="text-slate-400 font-medium pl-4 hover:text-white flex items-center gap-x-4 transition-colors duration-300" href="#">
                    <span class="material-symbols-outlined">subscriptions</span>
                    Your Library
                </a>
                <a class="text-slate-400 font-medium pl-4 hover:text-white flex items-center gap-x-4 transition-colors duration-300" href="#">
                    <span class="material-symbols-outlined">history_edu</span>
                    Followed Courses
                </a>
            </nav>
            <div class="mt-auto">
                <button class="w-full py-4 bg-primary-container text-on-primary font-bold rounded-full hover:scale-105 transition-transform">
                    Start New Unit
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="md:ml-64 min-h-screen pb-32">
        <!-- TopNavBar -->
        <header class="fixed top-0 right-0 w-full md:w-[calc(100%-16rem)] z-40 bg-[#041329]/80 dark:bg-[#041329]/80 backdrop-blur-xl font-['Plus_Jakarta_Sans'] font-semibold">
            <div class="flex justify-between items-center px-8 h-16">
                <div class="flex items-center gap-x-4 flex-1">
                    <div class="bg-surface-container-high rounded-full px-4 py-2 flex items-center gap-x-3 w-full max-w-md">
                        <span class="material-symbols-outlined text-slate-400">search</span>
                        <input class="bg-transparent border-none focus:ring-0 text-sm text-on-surface w-full" placeholder="What do you want to learn?" type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-x-6">
                    <button class="hover:bg-[#112036] rounded-full p-2 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-slate-300">notifications</span>
                    </button>
                    <button class="hover:bg-[#112036] rounded-full p-2 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-slate-300">settings</span>
                    </button>
                    <div class="w-8 h-8 rounded-full overflow-hidden">
                        <img class="w-full h-full object-cover" alt="close-up portrait of a professional man with friendly expression against a clean studio background, high-end photography" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCeBTrBJRjcR0GIKlQbpEQo-nSXs1z65Q9qOaHFhlikzyxl8BHpbjQAaim7B4bbsdMSHtwkxh7-hUiD9_ybMDayKtbUDBqfTXQ2dzsHZ9yqXmOmFMHrxX6tyScXzIwZ5xpjFJ-AnZrpB5Ffwfi1kI9UZvo6M-FD7rqApGaXV2kuovHZP06d_zfxZ6zSn0gLddc_yFhpvKsUVXzJ2c6O5OAea7_hWdKYKiAxeWOHpfqiAvFnrcyN9fjfIPC6CQiF4_uYy_oDPvFoh59B" />
                    </div>
                </div>
            </div>
        </header>

        <!-- Canvas -->
        <div class="pt-24 px-8 max-w-7xl mx-auto">
            <!-- Hero Section: Focus Mode -->
            <section class="mb-12">
                <div class="relative overflow-hidden rounded-xl bg-surface-container-low p-10 flex flex-col md:flex-row items-center gap-10">
                    <div class="absolute top-0 right-0 w-1/2 h-full opacity-20 pointer-events-none">
                        <div class="w-full h-full bg-gradient-to-l from-primary/40 to-transparent"></div>
                    </div>
                    <div class="z-10 flex-1">
                        <div class="flex items-center gap-x-2 text-primary mb-4">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">graphic_eq</span>
                            <span class="text-xs font-bold uppercase tracking-widest">Active immersion</span>
                        </div>
                        <h1 class="text-5xl font-extrabold tracking-tighter mb-4 leading-tight">
                            Focus Mode: <br /><span class="text-primary-fixed-dim">Spanish Verb Mastery</span>
                        </h1>
                        <p class="text-slate-400 max-w-md mb-8 body-lg">Deepen your subconscious recall with our 3D spatial audio environment designed for neurological retention.</p>
                        <div class="flex gap-x-4">
                            <button class="px-8 py-3 bg-primary-container text-on-primary rounded-full font-bold hover:scale-105 transition-all">Enter Focus Space</button>
                            <button class="px-8 py-3 bg-surface-container-highest text-on-surface rounded-full font-bold hover:bg-surface-bright transition-all">View Details</button>
                        </div>
                    </div>
                    <div class="relative z-10 w-full md:w-80 aspect-square rounded-lg overflow-hidden shadow-2xl">
                        <img class="w-full h-full object-cover" alt="cinematic close-up of high-quality vintage headphones on a wooden table with soft glowing neon green ambient light" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDem_rZRoDXEJ6o193ZpcVCxV9iFcZe5fxpJeye7AVOQ8NG_LLIwvUsBgG6grjsFgMYIGDyTrimR1OAmU0FGjBCWQ8M70eqqmdRON8FV_tiYFYfoP6K2QevyrgOgMkn1aMssftQP_oMWVzCyhd5u6JSdlgBM1LRzb7ViczZb0bzEGyH3FetC2Uuku1Jc_YMqgrYU0rtqA9TD9tj6Roi6pVljJes7_MUR9Vhh2sgJB0OrU39ns774ejpGyfh7BwkPJ1KBkPj8VahMrKT" />
                        <div class="absolute inset-0 bg-gradient-to-t from-surface-container-lowest/80 to-transparent flex items-end p-6">
                            <div class="flex items-center gap-x-3">
                                <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-on-primary">play_arrow</span>
                                </div>
                                <span class="font-bold text-sm">Resume Session</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Good Morning Section (Recent) -->
            <section class="mb-12">
                <h2 class="text-2xl font-bold tracking-tight mb-6">Good Morning</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var course in recentCourses)
                    {
                        <div class="group bg-surface-container hover:bg-surface-container-high transition-all rounded-md overflow-hidden flex items-center cursor-pointer">
                            <div class="w-20 h-20 flex-shrink-0">
                                <img class="w-full h-full object-cover" alt="@course.Alt" src="@course.ImageUrl" />
                            </div>
                            <div class="px-4 py-2 flex-1">
                                <p class="font-bold text-on-surface truncate">@course.Title</p>
                            </div>
                            <div class="pr-4 opacity-0 group-hover:opacity-100 transition-opacity">
                                <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center shadow-lg">
                                    <span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Made for Alex (Bento Inspired Recommendation) -->
            <section class="mb-12">
                <div class="flex justify-between items-end mb-6">
                    <div>
                        <h2 class="text-2xl font-bold tracking-tight">Made for Alex</h2>
                        <p class="text-slate-400 text-sm">Based on your recent progress in Germanic languages</p>
                    </div>
                    <button class="text-sm font-bold text-slate-400 hover:underline">Show all</button>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                    @foreach (var rec in recommendations)
                    {
                        var cardClasses = "bg-surface-container hover:bg-surface-container-high p-4 rounded-lg transition-all group cursor-pointer"
                                        + (rec.HiddenOnSmall ? " hidden lg:block" : string.Empty);
                        <div class="@cardClasses">
                            <div class="relative aspect-square mb-4 rounded-md overflow-hidden">
                                <img class="w-full h-full object-cover" alt="@rec.Alt" src="@rec.ImageUrl" />
                                <div class="absolute bottom-2 right-2 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all">
                                    <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center shadow-2xl">
                                        <span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                                    </div>
                                </div>
                            </div>
                            <h3 class="font-bold text-on-surface mb-1">@rec.Title</h3>
                            <p class="text-xs text-slate-400 line-clamp-2">@rec.Description</p>
                        </div>
                    }
                </div>
            </section>
        </div>
    </main>

    <!-- BottomNavBar (Player Shell) -->
    <footer class="fixed bottom-0 left-0 w-full z-50 h-24 rounded-t-[3rem] bg-[#112036]/90 dark:bg-[#112036]/90 backdrop-blur-2xl shadow-[0_-10px_40px_rgba(1,14,36,0.5)] flex justify-between items-center px-8">
        <!-- Now Playing -->
        <div class="flex items-center gap-x-4 w-1/3">
            <div class="w-14 h-14 rounded-lg overflow-hidden flex-shrink-0 shadow-lg">
                <img class="w-full h-full object-cover" alt="small thumbnail of headphones on a desk with green lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6_4Rbxe6GfUHpBO_BC9-_cDNX6lDNnP8HijDiWWLKtpDnzJesKF99L-r-CeVbgzlvimwwfHwdkPtu_wSQlsVFrHvXMUbUnxHMWL5b96fuk-MAAfAWNVWE7x4zbv7GQ0PJoI9klIeKVI4Ckga4k1sXO-33LxZw4E30nWCuAwPjEeoWW14lVX_PyOkOALxR8hQNPV0S_xpWUcRXHkQN2tVDwf0hdbIdwfDLHFXwcWbnnMWdgFbADTVX3z5HEohkWmGKKvYeXdvyxiy0" />
            </div>
            <div class="overflow-hidden">
                <h4 class="font-bold text-sm truncate">Verb Conjugation Drill</h4>
                <p class="text-xs text-slate-400 truncate">Spanish Intermediate • Unit 4</p>
            </div>
            <button class="hover:text-primary transition-colors ml-2">
                <span class="material-symbols-outlined text-[20px]">favorite</span>
            </button>
        </div>
        <!-- Player Controls -->
        <div class="flex flex-col items-center gap-y-2 w-1/3">
            <div class="flex items-center gap-x-6">
                <button class="text-slate-400 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">shuffle</span>
                </button>
                <button class="text-slate-400 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">skip_previous</span>
                </button>
                <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-black hover:scale-105 transition-transform active:scale-90">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                </button>
                <button class="text-slate-400 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">skip_next</span>
                </button>
                <button class="text-slate-400 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">repeat</span>
                </button>
            </div>
            <div class="flex items-center gap-x-2 w-full max-w-md">
                <span class="text-[10px] text-slate-400 font-bold">1:42</span>
                <div class="flex-1 h-1 bg-surface-container-highest rounded-full overflow-hidden">
                    <div class="w-1/3 h-full bg-primary relative">
                        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow-md hidden group-hover:block"></div>
                    </div>
                </div>
                <span class="text-[10px] text-slate-400 font-bold">4:50</span>
            </div>
        </div>
        <!-- Extra Actions -->
        <div class="flex items-center justify-end gap-x-4 w-1/3">
            <button class="text-slate-400 hover:text-primary transition-colors">
                <span class="material-symbols-outlined">lyrics</span>
            </button>
            <button class="text-slate-400 hover:text-primary transition-colors">
                <span class="material-symbols-outlined">queue_music</span>
