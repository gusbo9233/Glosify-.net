@{
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    ViewData["Title"] = "Flashcards";
}

<div class="flex flex-col items-center">
    <!-- Progress -->
    <div class="w-full max-w-3xl mb-16">
        <div class="flex justify-between items-end mb-4">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight text-on-surface">Vocabulary Mastery</h1>
                <p class="text-on-surface-variant text-sm mt-1">Japanese Philosophy Collection</p>
            </div>
            <div class="text-right">
                <span class="text-primary font-bold text-2xl">8</span>
                <span class="text-on-surface-variant/60 font-medium"> of 20 words</span>
            </div>
        </div>
        <div class="h-3 w-full bg-surface-container-highest rounded-full overflow-hidden">
            <div class="h-full w-[40%] bg-gradient-to-r from-primary to-primary-container rounded-full shadow-[0_0_15px_rgba(29,185,84,0.3)]"></div>
        </div>
    </div>

    <!-- Flashcard -->
    <div class="relative w-full max-w-2xl aspect-[1.6/1] mb-12">
        <div class="absolute inset-0 bg-surface-container-high/60 backdrop-blur-sm rounded-xl flex flex-col items-center justify-center p-12 text-center group cursor-pointer border border-outline-variant/10 shadow-2xl shadow-black/40">
            <div class="absolute top-8 left-8">
                <span class="px-3 py-1 rounded-full bg-surface-container-highest text-primary text-[10px] font-bold uppercase tracking-widest">Level 4</span>
            </div>
            <button type="button" class="mb-6">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl">volume_up</span>
            </button>
            <h2 class="text-7xl font-extrabold tracking-tighter text-on-surface mb-2">Kintsugi</h2>
            <p class="text-on-surface-variant/60 text-lg font-medium tracking-wide">きんつぎ</p>
            <div class="absolute bottom-8 right-8">
                <span class="material-symbols-outlined text-on-surface-variant/30">info</span>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col items-center gap-8 w-full max-w-2xl">
        <button type="button" class="w-full py-6 rounded-xl bg-primary-container text-on-primary text-xl font-extrabold shadow-xl shadow-primary/10 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
            Show Answer
        </button>
        <div class="flex items-center gap-6 w-full">
            <button type="button" class="flex-1 py-4 rounded-lg bg-surface-container-high text-on-surface-variant font-semibold hover:bg-surface-container-highest transition-colors">
                Skip
            </button>
            <div class="h-8 w-px bg-outline-variant/20"></div>
            <div class="flex-[3] flex gap-3">
                <button type="button" class="flex-1 py-4 rounded-lg bg-surface-container text-error font-bold text-sm border border-error/10 hover:bg-error/10 transition-all">
                    Again
                    <span class="block text-[10px] opacity-60 font-medium">1m</span>
                </button>
                <button type="button" class="flex-1 py-4 rounded-lg bg-surface-container text-on-surface font-bold text-sm border border-outline-variant/20 hover:bg-surface-container-highest transition-all">
                    Good
                    <span class="block text-[10px] opacity-60 font-medium">1d</span>
                </button>
                <button type="button" class="flex-1 py-4 rounded-lg bg-surface-container text-primary font-bold text-sm border border-primary/10 hover:bg-primary/10 transition-all">
                    Easy
                    <span class="block text-[10px] opacity-60 font-medium">4d</span>
                </button>
            </div>
        </div>
    </div>
</div>
