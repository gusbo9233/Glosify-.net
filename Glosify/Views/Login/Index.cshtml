@{
    Layout = "~/Views/Shared/_GlosifyLayout.cshtml";
    ViewData["Title"] = "Login";
}

<main class="auth-shell">
    <div class="brand-stack">
        <div class="brand-orb">
            <span class="material-symbols-outlined">graphic_eq</span>
        </div>
        <h1>Glosify</h1>
        <p class="brand-tagline">Sonic Language Immersion</p>
    </div>

    <section class="glass-card">
        <header class="auth-card-header">
            <h2>Welcome Back</h2>
            <p>Please enter your details to resume your journey.</p>
        </header>

        <form asp-controller="Home" asp-action="Index" method="get" class="auth-form">
            <div class="field">
                <label class="field-label" for="Email">Email Address</label>
                <input id="Email" name="Email" type="email"
                       class="field-input"
                       placeholder="name@@domain.com" autocomplete="email" />
            </div>

            <div class="field">
                <div class="field-row">
                    <label class="field-label" for="Password">Password</label>
                    <a class="field-link" asp-controller="Account" asp-action="ForgotPassword">Forgot?</a>
                </div>
                <input id="Password" name="Password" type="password"
                       class="field-input"
                       placeholder="••••••••" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-primary-pill">
                Log In
                <span class="material-symbols-outlined">arrow_forward</span>
            </button>
        </form>

        <div class="auth-divider" role="separator">
            <span>Or continue with</span>
        </div>

        <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="btn-social-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="provider" value="Google" />
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <button type="submit" class="btn-social">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDb84CkxQc5AKS9GScmkzh2AEulFhQWdAoHn7_HMmWS75aW9CH9-XHHKvv2RI-e9TUSbNbWTdUEtYIPZepEBsp7ngr3ICD5zwYpYW_kDJbcj6jaZ9zTZ6x3ieByU02YwnUz3uhwHlZFgi-AIuviWgnmjLzMNZFZLy-ICCqDiua1oRwdZj2rEtyOdj34lVx7AUWI-1pMgO0cbn2q7x1kzaUaBzRRc3CnlI4tggIUet-0CHHxOw0yHggpVlm4dUiUHbRoK3NiP_M6-BeD"
                     alt="Google logo" />
                Continue with Google
            </button>
        </form>

        <footer class="auth-footer">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Create Account</a>
        </footer>
    </section>

    <nav class="legal-links" aria-label="Legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Support</a>
    </nav>
</main>
