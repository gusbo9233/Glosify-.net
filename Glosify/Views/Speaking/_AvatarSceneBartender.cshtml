<div class="speaking-scene speaking-scene-prototype speaking-scene-bartender"
     data-avatar-scene="bartender"
     data-mouth-pose="closed"
     hidden>
<svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" role="img" aria-label="A detailed Polish bar scene with the bartender behind the counter">
  <defs>
    <linearGradient id="bartender-wallGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#1c130c"/>
      <stop offset="0.5" stop-color="#33210f"/>
      <stop offset="1" stop-color="#241608"/>
    </linearGradient>
    <linearGradient id="bartender-panelGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#4a2e14"/>
      <stop offset="1" stop-color="#2e1c0b"/>
    </linearGradient>
    <linearGradient id="bartender-counterGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#7a4a1e"/>
      <stop offset="0.12" stop-color="#5c3413"/>
      <stop offset="1" stop-color="#311a07"/>
    </linearGradient>
    <linearGradient id="bartender-backBarGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#503113"/>
      <stop offset="1" stop-color="#38200a"/>
    </linearGradient>
    <radialGradient id="bartender-lampGlowGrad" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="#ffce6b" stop-opacity="0.55"/>
      <stop offset="0.5" stop-color="#ffb347" stop-opacity="0.18"/>
      <stop offset="1" stop-color="#ffb347" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="bartender-beerGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#f5b93a"/>
      <stop offset="1" stop-color="#b96f10"/>
    </linearGradient>
    <linearGradient id="bartender-glassShine" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.35"/>
      <stop offset="0.25" stop-color="#ffffff" stop-opacity="0.05"/>
      <stop offset="1" stop-color="#ffffff" stop-opacity="0.12"/>
    </linearGradient>
    <filter id="bartender-neonGlow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="7" result="b"/>
      <feMerge>
        <feMergeNode in="b"/><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="bartender-softBlur"><feGaussianBlur stdDeviation="2.2"/></filter>
