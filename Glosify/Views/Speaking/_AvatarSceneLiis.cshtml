                <rect x="1170" y="315" width="48" height="73" rx="20" />
                <rect x="1322" y="315" width="48" height="73" rx="20" />
                <rect x="1397" y="315" width="48" height="73" rx="20" />
                <rect x="1247" y="232" width="46" height="76" rx="20" />
