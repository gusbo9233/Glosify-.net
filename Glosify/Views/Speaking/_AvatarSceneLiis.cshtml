         role="img"
         aria-label="Liis standing beside a path in Tallinn's Kadriorg park">
        <defs>
            <linearGradient id="liis-sky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#7fa6b8" />
                <stop offset=".68" stop-color="#c7d2c2" />
                <stop offset="1" stop-color="#e4d2a7" />
            </linearGradient>
            <linearGradient id="liis-grass" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#5f8155" />
                <stop offset="1" stop-color="#344f3e" />
            </linearGradient>
            <linearGradient id="liis-coat" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#866f9b" />
                <stop offset=".5" stop-color="#65527e" />
                <stop offset="1" stop-color="#403653" />
            </linearGradient>
            <linearGradient id="liis-scarf" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#dba56a" />
                <stop offset="1" stop-color="#a76e3f" />
            </linearGradient>
            <linearGradient id="liis-hair" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#d7a45f" />
                <stop offset=".52" stop-color="#a96d32" />
                <stop offset="1" stop-color="#70421f" />
