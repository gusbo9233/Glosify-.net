            <radialGradient id="liis-skin" cx="38%" cy="27%" r="74%">
                <stop offset="0" stop-color="#f7d3b2" />
                <stop offset=".62" stop-color="#e7af87" />
                <stop offset="1" stop-color="#c98564" />
            </radialGradient>
            <filter id="liis-soft-shadow" x="-30%" y="-30%" width="160%" height="180%">
                <feDropShadow dx="0" dy="18" stdDeviation="16" flood-color="#15271e" flood-opacity=".3" />
