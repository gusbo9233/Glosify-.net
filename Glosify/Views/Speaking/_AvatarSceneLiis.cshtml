                <g class="mouth-pose mouth-pose-narrow">
                    <ellipse cx="800" cy="475" rx="18" ry="6" fill="#773b42" />
                </g>
                <g class="mouth-pose mouth-pose-round">
                    <ellipse cx="800" cy="475" rx="10" ry="14" fill="#773b42" />
                </g>
                <g class="mouth-pose mouth-pose-open">
                    <ellipse cx="800" cy="475" rx="19" ry="14" fill="#693239" />
                    <path d="M785 468 H815" stroke="#f5e9dd" stroke-width="5" />
