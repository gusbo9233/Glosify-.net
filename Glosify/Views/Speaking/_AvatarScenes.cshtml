@model IReadOnlyList<Glosify.Services.Speaking.SpeakingPageAvatar>
@{
    var avatarIds = Model
        .Select(avatar => avatar.Id)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var craftedAvatarIds = new HashSet<string>(
        [
            "maarja", "karl", "liis",
            "hanna", "jonas", "frau-schneider",
            "oksana", "andriy", "pan-mykola"
        ],
        StringComparer.OrdinalIgnoreCase);
}

@if (avatarIds.Contains("bartender"))
{
    @await Html.PartialAsync("_AvatarSceneBartender")
}

@if (avatarIds.Contains("kasia"))
{
    @await Html.PartialAsync("_AvatarSceneKasia")
}

@if (avatarIds.Contains("mietek"))
{
    @await Html.PartialAsync("_AvatarSceneMietek")
}

@if (avatarIds.Contains("maarja"))
{
    @await Html.PartialAsync("_AvatarSceneMaarja")
}

@if (avatarIds.Contains("karl"))
{
    @await Html.PartialAsync("_AvatarSceneKarl")
}

@if (avatarIds.Contains("liis"))
{
    @await Html.PartialAsync("_AvatarSceneLiis")
}

@if (avatarIds.Contains("hanna"))
{
    @await Html.PartialAsync("_AvatarSceneHanna")
}

@if (avatarIds.Contains("jonas"))
{
    @await Html.PartialAsync("_AvatarSceneJonas")
}

@if (avatarIds.Contains("frau-schneider"))
{
    @await Html.PartialAsync("_AvatarSceneFrauSchneider")
}

@if (avatarIds.Contains("oksana"))
{
    @await Html.PartialAsync("_AvatarSceneOksana")
}

@if (avatarIds.Contains("andriy"))
{
    @await Html.PartialAsync("_AvatarSceneAndriy")
}

@if (avatarIds.Contains("pan-mykola"))
{
    @await Html.PartialAsync("_AvatarScenePanMykola")
}

@foreach (var avatar in Model.Where(avatar =>
    !string.Equals(avatar.SceneTemplate, "custom", StringComparison.OrdinalIgnoreCase)
    && !craftedAvatarIds.Contains(avatar.Id)))
{
    var backgroundId = $"{avatar.Id}-generated-background";
    var glowId = $"{avatar.Id}-generated-glow";
    var hairGradientId = $"{avatar.Id}-generated-hair";
    var shirtGradientId = $"{avatar.Id}-generated-shirt";
    var skinGradientId = $"{avatar.Id}-generated-skin";
    <div class="speaking-scene speaking-scene-generated speaking-scene-@avatar.Id speaking-scene-template-@avatar.SceneTemplate speaking-portrait-@avatar.PortraitStyle"
         data-avatar-scene="@avatar.Id"
         data-mouth-pose="closed"
         hidden>
        <svg viewBox="0 0 1600 900" role="img" aria-label="@avatar.Name at @avatar.Scenario">
            <defs>
                <linearGradient id="@backgroundId" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="var(--generated-scene-top)" />
                    <stop offset="1" stop-color="var(--generated-scene-bottom)" />
                </linearGradient>
                <radialGradient id="@glowId">
                    <stop offset="0" stop-color="var(--generated-accent)" stop-opacity=".38" />
                    <stop offset="1" stop-color="var(--generated-accent)" stop-opacity="0" />
                </radialGradient>
                <linearGradient id="@hairGradientId" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="color-mix(in srgb, var(--generated-hair) 72%, white)" />
                    <stop offset=".52" stop-color="var(--generated-hair)" />
                    <stop offset="1" stop-color="color-mix(in srgb, var(--generated-hair) 70%, black)" />
                </linearGradient>
                <linearGradient id="@shirtGradientId" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="color-mix(in srgb, var(--generated-shirt) 80%, white)" />
                    <stop offset=".48" stop-color="var(--generated-shirt)" />
                    <stop offset="1" stop-color="color-mix(in srgb, var(--generated-shirt) 72%, black)" />
                </linearGradient>
                <radialGradient id="@skinGradientId" cx="42%" cy="28%" r="74%">
                    <stop offset="0" stop-color="color-mix(in srgb, var(--generated-skin) 76%, white)" />
                    <stop offset=".58" stop-color="var(--generated-skin)" />
                    <stop offset="1" stop-color="color-mix(in srgb, var(--generated-skin) 82%, var(--generated-nose))" />
                </radialGradient>
            </defs>
            <rect width="1600" height="900" fill="@($"url(#{backgroundId})")" />
            <circle class="scene-glow" cx="800" cy="340" r="430" fill="@($"url(#{glowId})")" />

            @if (string.Equals(avatar.SceneTemplate, "cafe", StringComparison.OrdinalIgnoreCase))
            {
                <rect x="120" y="130" width="430" height="360" rx="24" fill="#dceaf1" opacity=".2" />
                <path d="M335 130 V490 M120 310 H550" stroke="#edf6fa" stroke-width="16" opacity=".28" />
                <g opacity=".72">
                    <circle cx="1320" cy="155" r="48" fill="var(--generated-lamp)" />
                    <path d="M1320 205 V330" stroke="var(--generated-lamp)" stroke-width="18" />
                    <path d="M1190 330 H1450" stroke="var(--generated-lamp)" stroke-width="24" stroke-linecap="round" />
                </g>
                <path d="M0 710 H1600 V900 H0 Z" fill="var(--generated-floor)" />
                <path d="M210 710 Q350 620 490 710 M1110 710 Q1250 620 1390 710" stroke="var(--generated-table)" stroke-width="34" fill="none" />
                <g transform="translate(1180 680)">
                    <rect x="0" y="-78" width="72" height="78" rx="10" fill="#f1eee4" />
                    <path d="M72 -58 Q112 -58 104 -26 Q96 -4 72 -12" fill="none" stroke="#f1eee4" stroke-width="14" />
                </g>
            }
            else if (string.Equals(avatar.SceneTemplate, "market", StringComparison.OrdinalIgnoreCase))
            {
                <path d="M70 250 H590 L530 390 H130 Z" fill="var(--generated-awning)" />
                <path d="M1010 250 H1530 L1470 390 H1070 Z" fill="var(--generated-awning-alt)" />
                <g fill="var(--generated-crate)" opacity=".9">
                    <rect x="120" y="610" width="310" height="160" rx="14" />
                    <rect x="1170" y="600" width="300" height="170" rx="14" />
                </g>
                <g fill="var(--generated-produce)">
                    <circle cx="180" cy="610" r="34" /><circle cx="250" cy="600" r="38" /><circle cx="330" cy="615" r="35" />
                    <circle cx="1230" cy="600" r="36" /><circle cx="1310" cy="590" r="38" /><circle cx="1390" cy="608" r="34" />
                </g>
                <path d="M0 765 H1600 V900 H0 Z" fill="var(--generated-floor)" />
            }
            else
            {
                <circle cx="250" cy="260" r="150" fill="var(--generated-tree)" opacity=".88" />
                <circle cx="1370" cy="230" r="180" fill="var(--generated-tree-alt)" opacity=".82" />
                <path d="M230 300 V690 M1370 300 V690" stroke="var(--generated-trunk)" stroke-width="54" />
                <path d="M0 650 Q420 560 800 650 T1600 650 V900 H0 Z" fill="var(--generated-grass)" />
                <g transform="translate(1130 690)">
                    <rect x="0" y="0" width="330" height="38" rx="10" fill="var(--generated-bench)" />
                    <rect x="20" y="70" width="290" height="34" rx="9" fill="var(--generated-bench)" />
                    <path d="M45 104 V175 M285 104 V175" stroke="var(--generated-bench-leg)" stroke-width="22" />
                </g>
            }

            <text x="800" y="105" text-anchor="middle" fill="var(--generated-sign)" font-size="42" font-family="Georgia,serif" letter-spacing="4">
                @avatar.SceneSign
            </text>

            <g class="avatar-figure generated-avatar-figure" data-avatar-figure>
                @if (avatar.PortraitStyle.Contains("woman", StringComparison.OrdinalIgnoreCase))
                {
                    <path d="M695 410 C670 285 720 220 800 220 C880 220 930 285 905 410 C892 478 925 548 902 620 C860 648 830 602 820 552 H780 C770 602 740 648 698 620 C675 548 708 478 695 410 Z" fill="@($"url(#{hairGradientId})")" />
                }
                <path d="M650 900 C650 720 700 595 800 595 C900 595 950 720 950 900 Z" fill="@($"url(#{shirtGradientId})")" />
                <path d="M674 900 C686 746 724 650 800 638 C876 650 914 746 926 900" stroke="color-mix(in srgb, var(--generated-shirt) 62%, white)" stroke-width="5" fill="none" opacity=".2" />
                <path d="M735 610 Q800 690 865 610 Q835 588 800 588 Q765 588 735 610 Z" fill="@($"url(#{skinGradientId})")" />
                <g class="avatar-gesture">
                    <path d="M875 630 Q970 690 950 760 Q930 790 900 755 L840 700" fill="@($"url(#{shirtGradientId})")" />
                    <ellipse cx="916" cy="756" rx="31" ry="22" fill="@($"url(#{skinGradientId})")" />
                </g>
                <rect x="777" y="520" width="46" height="88" rx="18" fill="@($"url(#{skinGradientId})")" />
                <g class="avatar-head">
                    <ellipse cx="724" cy="410" rx="16" ry="24" fill="@($"url(#{skinGradientId})")" />
                    <ellipse cx="876" cy="410" rx="16" ry="24" fill="@($"url(#{skinGradientId})")" />
                    <path d="M728 370 C728 300 756 262 800 262 C844 262 872 300 872 370 C872 455 846 520 800 520 C754 520 728 455 728 370 Z" fill="@($"url(#{skinGradientId})")" />
                    <path d="M733 422 C748 486 770 516 800 520 C830 516 852 486 867 422 C849 465 826 484 800 486 C774 484 751 465 733 422 Z" fill="var(--generated-nose)" opacity=".12" />
                    <ellipse cx="752" cy="448" rx="17" ry="9" fill="var(--generated-lip)" opacity=".12" />
                    <ellipse cx="848" cy="448" rx="17" ry="9" fill="var(--generated-lip)" opacity=".12" />
                    @if (!avatar.PortraitStyle.Contains("woman", StringComparison.OrdinalIgnoreCase))
                    {
                        <path d="M724 365 C720 286 755 246 800 246 C845 246 880 286 876 365 C850 330 750 330 724 365 Z" fill="@($"url(#{hairGradientId})")" />
                    }
                    else
                    {
                        <path d="M724 360 C720 282 755 244 800 244 C845 244 880 282 876 360 C852 322 748 322 724 360 Z" fill="@($"url(#{hairGradientId})")" />
                    }
                    <path d="M748 374 Q770 362 790 372 M810 372 Q830 362 852 374" stroke="var(--generated-brow)" stroke-width="7" fill="none" stroke-linecap="round" />
                    <g class="avatar-eyes">
                        <ellipse cx="770" cy="402" rx="14" ry="10" fill="#fffaf0" />
                        <ellipse cx="830" cy="402" rx="14" ry="10" fill="#fffaf0" />
                        <circle cx="772" cy="403" r="5.5" fill="var(--generated-eye)" />
                        <circle cx="828" cy="403" r="5.5" fill="var(--generated-eye)" />
                        <circle cx="774" cy="400" r="1.8" fill="#fff" />
                        <circle cx="830" cy="400" r="1.8" fill="#fff" />
                        <path d="M756 398 Q770 388 784 398 M816 398 Q830 388 844 398" stroke="var(--generated-brow)" stroke-width="2.5" fill="none" opacity=".55" />
                    </g>
                    <path d="M800 405 C795 427 792 438 796 444 Q800 449 804 444 C808 438 805 427 800 405 Z" fill="var(--generated-nose)" />
                    @if (string.Equals(avatar.PortraitStyle, "older-man", StringComparison.OrdinalIgnoreCase))
                    {
                        <path d="M768 462 Q800 445 832 462" stroke="var(--generated-grey)" stroke-width="8" fill="none" stroke-linecap="round" />
                    }
                    <g class="mouth-pose mouth-pose-closed"><path d="M775 476 Q800 488 825 476" stroke="var(--generated-lip)" stroke-width="5" fill="none" stroke-linecap="round" /></g>
                    <g class="mouth-pose mouth-pose-narrow"><ellipse cx="800" cy="478" rx="18" ry="7" fill="var(--generated-mouth)" /></g>
                    <g class="mouth-pose mouth-pose-round"><ellipse cx="800" cy="478" rx="11" ry="15" fill="var(--generated-mouth)" /></g>
                    <g class="mouth-pose mouth-pose-open"><ellipse cx="800" cy="478" rx="20" ry="15" fill="var(--generated-mouth)" /><path d="M785 470 H815" stroke="#f8efe4" stroke-width="5" /></g>
                </g>
            </g>
        </svg>
    </div>
}
